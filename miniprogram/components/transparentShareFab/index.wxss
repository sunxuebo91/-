.tsf-wrap {
  position: fixed;
  right: 24rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  z-index: 200;
}

.tsf-btn {
  box-sizing: border-box;
  width: 100rpx !important;
  min-width: 0 !important;
  max-width: 100rpx !important;
  height: 100rpx !important;
  border-radius: 50% !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.98) !important;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  margin: 0 !important;
  padding: 0 !important;
  font-size: 0;
  line-height: 1;
  overflow: hidden;
  transition: transform 0.15s ease;
}

.tsf-btn::after {
  border: none !important;
  border-radius: 50% !important;
}

.tsf-btn-hover {
  transform: scale(0.93);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.18);
}

.tsf-btn-disabled {
  opacity: 0.6;
}

.tsf-btn-icon {
  font-size: 36rpx;
  line-height: 1;
  color: #2c2c2c;
}

.tsf-btn-label {
  font-size: 20rpx;
  color: #555;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

.tsf-btn-share .tsf-btn-icon {
  color: #00897B;
  font-weight: 700;
}

.tsf-btn-poster .tsf-btn-icon {
  color: #C8A96E;
}

.tsf-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750px;
  height: 1500px;
  pointer-events: none;
}
