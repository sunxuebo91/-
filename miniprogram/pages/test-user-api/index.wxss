.container {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 按钮区域 */
.buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-info {
  background: #3498db;
  color: #fff;
}

.btn-success {
  background: #2ecc71;
  color: #fff;
}

.btn-warning {
  background: #f39c12;
  color: #fff;
}

/* 测试结果 */
.results {
  background: #fff;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.result-status {
  font-size: 28rpx;
  font-weight: 600;
}

.result-status.success {
  color: #2ecc71;
}

.result-status.failed {
  color: #e74c3c;
}

.result-status.error {
  color: #f39c12;
}

/* 日志区域 */
.logs {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}

.logs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #e9ecef;
}

.logs-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.logs-count {
  font-size: 24rpx;
  color: #999;
}

.logs-content {
  height: 800rpx;
  padding: 24rpx 32rpx;
}

.log-item {
  font-size: 26rpx;
  line-height: 44rpx;
  color: #666;
  margin-bottom: 12rpx;
  padding: 12rpx;
  border-radius: 8rpx;
  word-break: break-all;
  font-family: 'Courier New', monospace;
}

.log-item.success {
  background: #d4edda;
  color: #155724;
}

.log-item.error {
  background: #f8d7da;
  color: #721c24;
}

.log-item.warning {
  background: #fff3cd;
  color: #856404;
}

.log-item.test {
  background: #d1ecf1;
  color: #0c5460;
  font-weight: 600;
}

.log-empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* 说明 */
.tips {
  background: #fff;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tips-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 44rpx;
  margin-bottom: 8rpx;
}

