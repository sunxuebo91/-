page {
  background: #f7f7fb;
}

.transparent-service {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 板块容器 */
.section {
  margin: 24rpx 20rpx 8rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 16rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 板块标题 */
.section-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 4rpx 12rpx 16rpx;
  border-bottom: 1rpx dashed #ececf2;
  margin-bottom: 16rpx;
}

.section-emoji {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2c2c2c;
  letter-spacing: 1rpx;
}

.section-sub {
  font-size: 22rpx;
  color: #999;
  margin-left: auto;
  letter-spacing: 1rpx;
}

/* 内容区域:3个一行,超出换行 */
.content {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

/* 报价卡片通用样式：正方形，4个一行 */
.price-card {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.price-card:active {
  transform: scale(0.95);
}

/* 月嫂报价卡片 - 粉色 */
.price-card-pink {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA8C5 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 157, 0.35);
}

/* 育儿报价卡片 - 紫色 */
