<view class="transparent-service">
  <!-- 内容区域 -->
  <view class="content">
    <!-- 月嫂报价卡片 -->
    <view class="price-card price-card-pink" bindtap="goMaternityPricing">
      <view class="price-card-content">
        <view class="price-card-title">月嫂报价</view>
        <view class="price-card-subtitle">查看详细服务价格</view>
      </view>
      <image class="price-card-image" src="/images/icons/yuexin.svg" mode="aspectFit"></image>
    </view>

    <!-- 育儿报价卡片 -->
    <view class="price-card price-card-purple" bindtap="goChildcarePricing">
      <view class="price-card-content">
        <view class="price-card-title">育儿报价</view>
        <view class="price-card-subtitle">查看详细服务价格</view>
      </view>
      <image class="price-card-image" src="/images/icons/yuer.svg" mode="aspectFit"></image>
    </view>

    <!-- 保姆报价卡片 -->
    <view class="price-card price-card-orange" bindtap="goNannyPricing">
      <view class="price-card-content">
        <view class="price-card-title">保姆报价</view>
        <view class="price-card-subtitle">查看详细服务价格</view>
      </view>
      <image class="price-card-image" src="/images/icons/baomu.svg" mode="aspectFit"></image>
    </view>

    <!-- 护老报价卡片 -->
    <view class="price-card price-card-yellow" bindtap="goEldercarePricing">
      <view class="price-card-content">
        <view class="price-card-title">护老报价</view>
        <view class="price-card-subtitle">查看详细服务价格</view>
      </view>
      <image class="price-card-image" src="/images/icons/hulao.svg" mode="aspectFit"></image>
    </view>
  </view>
</view>

