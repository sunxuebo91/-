<view class="page">

  <!-- Hero -->
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-badge">国标育婴员 · WHO 早期发展 · 24h 守护</view>
    <view class="hero-title">育儿嫂一日工作流程</view>
    <view class="hero-sub">分龄照护 · 早教启蒙 · 体格智能并重</view>
    <view class="hero-stats">
      <view class="stat-item">
        <text class="stat-num">6</text>
        <text class="stat-label">个时段</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">33</text>
        <text class="stat-label">项关键工作</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">0-3y</text>
        <text class="stat-label">服务年龄</text>
      </view>
    </view>
  </view>

  <!-- 图例 -->
  <view class="legend">
    <view class="legend-row">
      <view class="legend-tag">分龄照护</view>
      <view class="legend-tag">早教启蒙</view>
      <view class="legend-tag">营养辅食</view>
      <view class="legend-tag">体格锻炼</view>
      <view class="legend-tag">习惯培养</view>
    </view>
    <text class="legend-text">参考人社部国家职业标准《育婴员》(GZB-4-12-01-04)、中国妇幼保健协会《育婴师培训规范》、《中国居民膳食指南·婴幼儿喂养(2022)》、WHO《0-5 岁儿童身体活动/久坐/睡眠指南》、AAP《婴幼儿屏幕时间建议》、UNICEF 早期儿童发展(ECD)框架</text>
  </view>

  <!-- 时间轴：6 时段 -->
  <view class="timeline">
    <view class="tl-row" wx:for="{{phases}}" wx:key="title" wx:for-item="ph">
      <view class="tl-side">
        <view class="tl-dot">
          <text class="tl-dot-text">{{ph.dot}}</text>
        </view>
        <view class="tl-line" wx:if="{{index !== phases.length - 1}}"></view>
      </view>

      <view class="tl-card">
        <view class="tl-card-head">
          <view class="tl-age">{{ph.title}}</view>
          <view class="tl-hint">{{ph.hint}}</view>
          <view class="tl-feature">{{ph.feature}}</view>
        </view>

        <view class="task-block" wx:for="{{ph.items}}" wx:key="t" wx:for-item="it">
          <view class="task-title">{{it.t}}</view>
          <view class="task-desc">{{it.d}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部贴士 -->
  <view class="bottom-note">
    <view class="note-title">📋 育儿嫂工作必读专业提醒</view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">📑</text><text class="tip-title">国家标准与职业规范</text></view>
      <view class="tip-desc">人社部《育婴员国家职业标准》(GZB-4-12-01-04)、中国妇幼保健协会《育婴师培训规范》、《婴幼儿喂养指南(2022)》——服务流程以国标为基准,持证上岗,定期参加技能复训</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">⚠️</text><text class="tip-title">宝宝红色信号</text></view>
      <view class="tip-desc">高热惊厥 / 持续呕吐腹泻脱水 / 呼吸困难紫绀 / 意识改变嗜睡 / 严重外伤跌落 / 异物窒息 / 拒食拒水 ≥ 12h / 皮肤瘀点瘀斑——立即通知家长并 120 就医</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🍼</text><text class="tip-title">分龄喂养黄金原则</text></view>
      <view class="tip-desc">0-6 月纯母乳/配方奶按需喂养、不加水不加辅食;6-24 月母乳 + 辅食(铁强化米粉先行)、由稀到稠由细到粗、新食物 3-5 天观察过敏;2-3 岁过渡到家庭饮食,奶量 ≥ 500ml/天</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🚼</text><text class="tip-title">儿童伤害六大防范</text></view>
      <view class="tip-desc">防跌落(婴儿床护栏 / 楼梯门)、防烫伤(热水温度 ≤ 50°C)、防异物窒息(食物 ≤ 3.5cm 不带核)、防溺水(澡盆 5cm 水即危险不离人)、防触电(插座保护盖)、防误食(药品/清洁剂高处上锁)</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">📱</text><text class="tip-title">屏幕时间限制</text></view>
      <view class="tip-desc">WHO/AAP 共识:18 月以下零屏幕(视频通话除外)、18-24 月仅高质量节目陪同观看、2-5 岁 ≤ 1 小时/天;育儿嫂工作期间不看手机刷视频,不让宝宝看动画片代替陪伴</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🤸</text><text class="tip-title">大运动里程碑</text></view>
      <view class="tip-desc">抬头(3 月)/翻身(4-6 月)/独坐(6-8 月)/爬行(8-10 月)/独走(12-15 月)/跑跳(18-24 月)/单脚站(3 岁);落后 ≥ 2 月需儿保科评估,不强行训练,提供安全环境鼓励自主探索</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🗣️</text><text class="tip-title">语言里程碑</text></view>
      <view class="tip-desc">咿呀发音(2-3 月)/牙牙学语(6 月)/单词(12 月)/双词句(18 月)/简单句(2 岁)/对话(2-3 岁);多说少问、丰富语境、不学叠字奶音、不替宝宝说;2 岁仍无单词需评估听力与语言发育</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">📊</text><text class="tip-title">体格生长监测</text></view>
      <view class="tip-desc">每月测身高/体重/头围(0-12 月)、每 3 月测(1-3 岁);WHO 生长曲线 P3-P97 为正常;体重连续 2 月不增、身高低于 P3、头围异常增大需儿保科就诊;按月写《育婴日志》</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🚭</text><text class="tip-title">必要禁忌</text></view>
      <view class="tip-desc">不喂蜂蜜(&lt; 1 岁,肉毒杆菌)/不喂整粒坚果果冻葡萄(&lt; 3 岁,呛噎)/不强迫进食追喂打饭/不摇晃宝宝(摇晃综合征)/不打骂体罚语言暴力/不擅自喂药保健品/不与宝宝亲嘴防疱疹</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">👩‍⚕️</text><text class="tip-title">个体化原则</text></view>
      <view class="tip-desc">早产儿矫正月龄计算、过敏体质忌口清单、特殊需求儿童(脑瘫/听障/孤独症)需康复方案配合、慢病用药等情况,流程需按医师与家长共同协商调整;育儿嫂只做生活照护与启蒙,不替代医疗</view>
    </view>
  </view>

  <view class="footer-tip">· 安得褓贝 · 用心陪伴每一天 ·</view>

  <transparent-share-fab
    page-title="育儿嫂一日工作流程"
    page-subtitle="0-3 岁分龄照护 · 早教启蒙"
    page-badge="育婴员国标 · 体格智能并重"
    theme-color="#7B1FA2"
    theme-color-light="#BA68C8"
    stats="{{[{num:'6',label:'时段'},{num:'33',label:'项工作'},{num:'0-3',label:'岁服务'}]}}"
    summary-lines="{{['晨间：晨检 / 喂养 / 如厕训练 / 自理培养','上午：90 分钟户外 / 分龄早教 / 辅食制作','午间：自主进食 / 独立入睡 / 午睡看护','下午：大运动 60 分 / 精细动作 / 社交活动','晚间：亲子阅读 / 睡前仪式 / 抚触被动操']}}"
  />
</view>
