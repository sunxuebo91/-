.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
}

/* 关联订单卡片 */
.order-card {
  background: linear-gradient(135deg, #f0ebff, #e8e0ff);
  border-radius: 20rpx;
  padding: 28rpx 32rpx 20rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #8766F3;
}
.order-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8766F3;
  margin-bottom: 20rpx;
}
.order-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(135,102,243,0.12);
}
.order-row:last-child { border-bottom: none; }
.order-label {
  font-size: 26rpx;
  color: #888;
}
.order-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
}
.order-salary { color: #8766F3; font-weight: 700; }
.order-loading {
  background: #f9f9f9;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  text-align: center;
}
.order-loading-text { font-size: 26rpx; color: #aaa; }

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 32rpx 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
}
.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item.last { border-bottom: none; margin-bottom: 16rpx; }
.form-label {
  font-size: 28rpx;
  color: #555;
  display: block;
  margin-bottom: 12rpx;
}
.req { color: #e74c3c; }
.form-tip { font-size: 24rpx; color: #aaa; }
.form-input {
  width: 100%;
  font-size: 30rpx;
  color: #222;
  height: 72rpx;
  line-height: 72rpx;
}
.form-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #222;
  min-height: 120rpx;
  line-height: 1.7;
  padding-top: 8rpx;
}

/* 服务类型选择器 */
.picker-row {
  display: flex; align-items: center; justify-content: space-between;
  height: 72rpx;
}
.picker-placeholder { font-size: 30rpx; color: #bbb; }
.picker-value { font-size: 30rpx; color: #222; }
.picker-arrow { font-size: 40rpx; color: #bbb; }

/* 提示卡片 */
.tip-card {
  background: #fffbe6;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
}
.tip-text { font-size: 24rpx; color: #b8860b; line-height: 1.7; }

/* 提交按钮 */
.btn-wrap {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.submit-btn {
  width: 100%; height: 96rpx;
  background: #8766F3; color: #fff;
  font-size: 34rpx; font-weight: 600;
  border-radius: 48rpx; border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
}
.btn-disabled { background: #c4b8f5 !important; }
