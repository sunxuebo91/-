<view class="page">

  <!-- 关联客户订单卡片（来源海报绑定的订单需求） -->
  <view class="order-card" wx:if="{{customerInfo}}">
    <view class="order-card-title">📋 关联客户需求</view>
    <view class="order-row" wx:if="{{customerInfo.orderType}}">
      <text class="order-label">服务类型</text>
      <text class="order-value">{{customerInfo.orderType}}</text>
    </view>
    <view class="order-row" wx:if="{{customerInfo.salary}}">
      <text class="order-label">期望薪资</text>
      <text class="order-value order-salary">¥{{customerInfo.salary}}/月</text>
    </view>
    <view class="order-row" wx:if="{{customerInfo.serviceAddress}}">
      <text class="order-label">服务地址</text>
      <text class="order-value">{{customerInfo.serviceAddress}}</text>
    </view>
    <view class="order-row" wx:if="{{customerInfo.onboardingTime}}">
      <text class="order-label">上户时间</text>
      <text class="order-value">{{customerInfo.onboardingTime}}</text>
    </view>
  </view>
  <!-- 订单加载中占位 -->
  <view class="order-loading" wx:elif="{{customerLoading}}">
    <text class="order-loading-text">⏳ 加载关联订单...</text>
  </view>

  <view class="form-card">
    <view class="section-title">被推荐阿姨信息</view>

    <view class="form-item">
      <text class="form-label">阿姨姓名 <text class="req">*</text></text>
      <input class="form-input" placeholder="请输入真实姓名"
             value="{{form.name}}" bindinput="onInput" data-field="name"/>
    </view>

    <view class="form-item">
      <text class="form-label">手机号 <text class="req">*</text></text>
      <input class="form-input" type="number" maxlength="11"
             placeholder="请输入手机号" value="{{form.phone}}"
             bindinput="onInput" data-field="phone"/>
    </view>

    <view class="form-item">
      <text class="form-label">服务类型 <text class="req">*</text></text>
      <picker mode="selector" range="{{serviceTypes}}" range-key="label"
              value="{{serviceTypeIndex}}" bindchange="onServiceTypeChange">
        <view class="picker-row">
          <text class="{{serviceTypeIndex >= 0 ? 'picker-value' : 'picker-placeholder'}}">
            {{serviceTypeIndex >= 0 ? serviceTypes[serviceTypeIndex].label : '请选择服务类型'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item last">
      <text class="form-label">备注说明</text>
      <textarea class="form-textarea" placeholder="其他补充说明（选填）"
                value="{{form.remark}}" bindinput="onInput" data-field="remark"/>
    </view>
  </view>

  <view class="tip-card">
    <text class="tip-text">⚠️ 同一手机号或身份证号仅可录入一次，重复录入将被拒绝</text>
  </view>

  <view class="btn-wrap">
    <button class="submit-btn {{submitting ? 'btn-disabled' : ''}}"
            bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交推荐'}}
    </button>
  </view>

</view>
