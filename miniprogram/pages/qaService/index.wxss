page {
  background: #f7f7fb;
}

.qa-service {
  min-height: 100vh;
}

/* 内容区域（对齐 transparentService 页面） */
.content {
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 报价卡片通用样式（对齐 transparentService 页面） */
.price-card {
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

/* 重置 button 样式 */
.price-card-button {
  background: none;
  border: none;
  margin: 0;
  line-height: normal;
  text-align: left;
  width: 100%;
}

.price-card-button::after {
  border: none;
}

.price-card:active {
  transform: translateY(4rpx);
}

/* 主题色：紫色（对齐育儿报价） */
.price-card-purple {
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  box-shadow: 0 8rpx 24rpx rgba(135, 102, 243, 0.3);
}

.price-card-purple:active {
  box-shadow: 0 4rpx 12rpx rgba(135, 102, 243, 0.2);
}

/* 主题色：蓝色（合同预览） */
.price-card-blue {
  background: linear-gradient(135deg, #4A90E2 0%, #5BA3F5 100%);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.3);
}

.price-card-blue:active {
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.2);
}

/* 主题色：绿色（小时工合同预览） */
.price-card-green {
  background: linear-gradient(135deg, #52C41A 0%, #73D13D 100%);
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
}

.price-card-green:active {
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.2);
}

/* 主题色：橙色（育儿嫂合同预览） */
.price-card-orange {
  background: linear-gradient(135deg, #FA8C16 0%, #FFA940 100%);
  box-shadow: 0 8rpx 24rpx rgba(250, 140, 22, 0.3);
}

.price-card-orange:active {
  box-shadow: 0 4rpx 12rpx rgba(250, 140, 22, 0.2);
}

/* 主题色：青色（月嫂合同-定金） */
.price-card-cyan {
  background: linear-gradient(135deg, #13C2C2 0%, #36CFC9 100%);
  box-shadow: 0 8rpx 24rpx rgba(19, 194, 194, 0.3);
}

.price-card-cyan:active {
  box-shadow: 0 4rpx 12rpx rgba(19, 194, 194, 0.2);
}

/* 主题色：玫红（月嫂合同-全款） */
.price-card-pink {
  background: linear-gradient(135deg, #EB2F96 0%, #F759AB 100%);
  box-shadow: 0 8rpx 24rpx rgba(235, 47, 150, 0.3);
}

.price-card-pink:active {
  box-shadow: 0 4rpx 12rpx rgba(235, 47, 150, 0.2);
}

/* 主题色：红色（不退费合同） */
.price-card-red {
  background: linear-gradient(135deg, #CF1322 0%, #F5222D 100%);
  box-shadow: 0 8rpx 24rpx rgba(207, 19, 34, 0.3);
}

.price-card-red:active {
  box-shadow: 0 4rpx 12rpx rgba(207, 19, 34, 0.2);
}




.price-card-content {
  flex: 1;
}

.price-card-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.price-card-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.price-card-image {
  width: 120rpx;
  height: 120rpx;
  margin-left: 24rpx;
}