.page {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 200rpx;
}

/* 离屏 canvas：用于动态生成分享缩略图（绝对定位到视口外，不影响布局） */
.assessment-share-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 500px;
  height: 400px;
  pointer-events: none;
}

/* 头图 */
.hero {
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  padding: 60rpx 40rpx 50rpx;
  border-radius: 0 0 32rpx 32rpx;
}
.hero-title { font-size: 52rpx; font-weight: 700; letter-spacing: 2rpx; }
.hero-subtitle { font-size: 26rpx; margin-top: 12rpx; opacity: 0.9; }
.hero-tags { display: flex; gap: 12rpx; margin-top: 28rpx; flex-wrap: wrap; }
.hero-tag {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.22);
  border-radius: 24rpx;
  font-size: 22rpx;
}

/* 员工专属右下角悬浮分享按钮（仅员工可见） */
.staff-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #1a0a2e 0%, #3b1d6e 55%, #8766F3 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #FAF6EE;
  box-shadow: 0 8rpx 24rpx rgba(60, 30, 110, 0.42), 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
  z-index: 99;
  border: 2rpx solid rgba(200, 169, 110, 0.4);
}
.staff-fab-icon { font-size: 38rpx; line-height: 1; }
.staff-fab-label {
  font-size: 20rpx;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
  color: #C8A96E;
  font-weight: 600;
}

/* 流程卡 */
.flow-card {
  margin: -28rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 24rpx rgba(135,102,243,0.08);
}
.flow-step { display: flex; flex-direction: column; align-items: center; flex: 1; }
.flow-num {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: linear-gradient(135deg, #8766F3, #A694FF);
  color: #fff; font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 10rpx;
}
.flow-text { font-size: 22rpx; color: #444; text-align: center; }
.flow-arrow { color: #ccc; font-size: 36rpx; padding: 0 8rpx; }

/* 表单 */
.form-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 36rpx 28rpx 28rpx;
}
.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #8766F3;
  padding-left: 14rpx;
}
.form-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 24rpx 0;
}
.form-row:last-of-type { border-bottom: none; }
.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.form-label .required {
  color: #ff4d4f;
  margin-right: 6rpx;
  font-weight: 600;
}
.phone-input { flex: 1; min-width: 0; }
.phone-auth-btn-mini {
  flex: 0 0 auto !important;
  width: auto !important;
  min-width: 0 !important;
  max-width: 160rpx;
  height: 48rpx !important;
  line-height: 46rpx !important;
  padding: 0 18rpx !important;
  font-size: 20rpx !important;
  color: #8766F3 !important;
  background: rgba(135, 102, 243, 0.08) !important;
  border: 1rpx solid rgba(135, 102, 243, 0.32) !important;
  border-radius: 24rpx !important;
  margin: 0 0 0 12rpx !important;
}
.phone-auth-btn-mini::after { border: none !important; }
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}
.form-picker {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.form-picker.placeholder .form-picker-text { color: #aaa; }
.form-picker-text { flex: 1; }
.picker-arrow {
  width: 0;
  height: 0;
  margin-left: 12rpx;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid #bbb;
  flex-shrink: 0;
}

.form-tips {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
  text-align: center;
}

.footer-spacer { height: 200rpx; }

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  z-index: 100;
}

.advisor-mini {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  max-width: 260rpx;
}
.advisor-mini-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx; font-weight: 700;
  overflow: hidden; flex-shrink: 0;
}
.advisor-avatar-img { width: 100%; height: 100%; border-radius: 36rpx; }
.advisor-mini-info { min-width: 0; }
.advisor-mini-name {
  font-size: 26rpx; font-weight: 600; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  max-width: 180rpx;
}
.advisor-mini-company { font-size: 22rpx; color: #888; }

.primary-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  margin: 0;
  padding: 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.primary-btn::after { border: none; }
.primary-btn[disabled] { opacity: 0.6; color: #fff; background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%); }