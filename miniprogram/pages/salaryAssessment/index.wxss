.page {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 200rpx;
}

/* 头图 */
.hero {
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  padding: 60rpx 40rpx 50rpx;
  border-radius: 0 0 32rpx 32rpx;
}
.hero-title { font-size: 52rpx; font-weight: 700; letter-spacing: 2rpx; }
.hero-subtitle { font-size: 26rpx; margin-top: 12rpx; opacity: 0.9; }
.hero-tags { display: flex; gap: 12rpx; margin-top: 28rpx; flex-wrap: wrap; }
.hero-tag {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.22);
  border-radius: 24rpx;
  font-size: 22rpx;
}

/* 流程卡 */
.flow-card {
  margin: -28rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 24rpx rgba(135,102,243,0.08);
}
.flow-step { display: flex; flex-direction: column; align-items: center; flex: 1; }
.flow-num {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: linear-gradient(135deg, #8766F3, #A694FF);
  color: #fff; font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 10rpx;
}
.flow-text { font-size: 22rpx; color: #444; text-align: center; }
.flow-arrow { color: #ccc; font-size: 36rpx; padding: 0 8rpx; }

/* 表单 */
.form-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 36rpx 28rpx 28rpx;
}
.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #8766F3;
  padding-left: 14rpx;
}
.form-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 24rpx 0;
}
.form-row:last-of-type { border-bottom: none; }
.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.form-label .required {
  color: #ff4d4f;
  margin-right: 6rpx;
  font-weight: 600;
}
.phone-readonly { color: #1a1a1a; }
.phone-lock { color: #bbb; font-size: 24rpx; margin-left: 8rpx; }
.phone-auth-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  border-radius: 32rpx;
  border: none;
  margin: 0;
  padding: 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.phone-auth-btn::after { border: none; }
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}
.form-picker {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.form-picker.placeholder { color: #aaa; }
.picker-arrow { color: #ccc; font-size: 32rpx; transform: rotate(90deg); }

.form-tips {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
  text-align: center;
}

.footer-spacer { height: 200rpx; }

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  z-index: 100;
}

.advisor-mini {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  max-width: 260rpx;
}
.advisor-mini-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx; font-weight: 700;
  overflow: hidden; flex-shrink: 0;
}
.advisor-avatar-img { width: 100%; height: 100%; border-radius: 36rpx; }
.advisor-mini-info { min-width: 0; }
.advisor-mini-name {
  font-size: 26rpx; font-weight: 600; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  max-width: 180rpx;
}
.advisor-mini-company { font-size: 22rpx; color: #888; }

.primary-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  margin: 0;
  padding: 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.primary-btn::after { border: none; }
.primary-btn[disabled] { opacity: 0.6; color: #fff; background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%); }