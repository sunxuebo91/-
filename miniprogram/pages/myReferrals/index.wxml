<view class="page">

  <!-- 顶部统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">累计推荐</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.contracted}}</text>
      <text class="stat-label">已签单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num green">¥{{stats.totalReward}}</text>
      <text class="stat-label">累计返费</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="state-icon">⏳</view>
    <view class="state-text">加载中...</view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{list.length === 0}}" class="state-wrap">
    <view class="state-icon">👥</view>
    <view class="state-text">还没有推荐记录</view>
    <view class="state-sub">点击下方按钮，录入您推荐的阿姨</view>
  </view>

  <!-- 推荐列表 -->
  <view wx:else class="list">
    <view class="referral-card" wx:for="{{list}}" wx:key="_id"
          bindtap="goDetail" data-id="{{item._id}}">
      <view class="card-header">
        <text class="auntie-name">{{item.name}}</text>
        <view class="status-tag status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">服务类型</text>
          <text class="info-value">{{item.serviceTypeText}}</text>
        </view>
        <view class="info-row" wx:if="{{item.contractedAtFmt}}">
          <text class="info-label">签单时间</text>
          <text class="info-value">{{item.contractedAtFmt}}</text>
        </view>
        <view class="info-row reward-row" wx:if="{{item.rewardAmount}}">
          <text class="info-label">预计返费</text>
          <text class="info-value reward-val">¥{{item.rewardAmount}}</text>
        </view>
      </view>
      <view class="card-footer">
        <text class="submit-time">提交于 {{item.createdAtFmt}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 新增推荐悬浮按钮 -->
  <view class="fab" bindtap="goSubmit">
    <text class="fab-icon">+</text>
    <text class="fab-text">推荐阿姨</text>
  </view>

</view>
