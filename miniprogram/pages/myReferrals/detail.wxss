.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 200rpx); /* 已上户时底部申请结算按钮留空，含安全区 */
  box-sizing: border-box;
}

/* 状态头部 */
.status-header {
  background: linear-gradient(135deg, #8766F3, #a48ef5);
  padding: 48rpx 40rpx 56rpx;
  display: flex; flex-direction: column; align-items: center;
  gap: 16rpx;
}
.status-tag {
  font-size: 24rpx; padding: 8rpx 24rpx;
  border-radius: 20rpx; font-weight: 500;
}
.status-pending         { background: rgba(255,255,255,0.25); color: #fff; }
.status-pending_review  { background: rgba(255,255,255,0.25); color: #fff; }
.status-rejected        { background: #fde8e8; color: #e74c3c; }
.status-following_up    { background: #e8f0ff; color: #3b82f6; }
.status-contracted      { background: #e8fdf0; color: #16a34a; }
.status-onboarded       { background: #fffbe6; color: #d97706; }
.status-reward_pending  { background: #fff3e0; color: #f97316; }
.status-reward_approved { background: #e0f2fe; color: #0369a1; }
.status-reward_paid     { background: #dcfce7; color: #15803d; }
.status-invalid         { background: #fde8e8; color: #e74c3c; }
.auntie-name { font-size: 44rpx; font-weight: 700; color: #fff; }
.service-type { font-size: 28rpx; color: rgba(255,255,255,0.85); }

/* 通用信息卡片 */
.section-card {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 28rpx; font-weight: 600; color: #333;
  margin-bottom: 20rpx;
}
.info-row {
  display: flex; align-items: center; justify-content: space-between;
  min-height: 72rpx;           /* 固定行高，消除 line-box 高度差导致的视觉错位 */
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  box-sizing: border-box;
}
/* 最后一行去掉分隔线 */
.info-row:last-child,
.info-row.last { border-bottom: none; }
/* label / value 统一字号和行高，避免 line-box 不等高 */
.label { font-size: 28rpx; color: #999; min-width: 140rpx; line-height: 1.5; }
.value { font-size: 28rpx; color: #333; flex: 1; text-align: right; line-height: 1.5; }
.value.green { color: #16a34a; font-weight: 600; }
.value.orange { color: #f97316; }
.reward-val { color: #22c55e; font-weight: 700; font-size: 32rpx; }
.blue { color: #0369a1; font-weight: 600; }

/* 合同记录 */
.contract-num { font-family: monospace; font-size: 26rpx; color: #8766F3; }
.fee-val { color: #e67e22; font-weight: 600; }
.contract-empty { font-size: 26rpx; color: #bbb; }

/* ── 申请结算 ── */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 40rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.08);
}
.settle-btn {
  background: #8766F3; color: #fff; text-align: center;
  font-size: 32rpx; font-weight: 600; padding: 28rpx 0;
  border-radius: 16rpx;
}

/* 蒙层 */
.settle-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 100;
}
/* 底部弹窗 */
.settle-sheet {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 101;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  /* 修复：给整个弹窗内容区设定最大高度并允许滚动，防止键盘弹起时内容被挤压 */
  max-height: 80vh; overflow-y: auto; box-sizing: border-box;
}
.settle-sheet-title {
  font-size: 34rpx; font-weight: 700; color: #1a1a1a;
  text-align: center; margin-bottom: 40rpx;
}
.settle-field { margin-bottom: 32rpx; }
.settle-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 12rpx; }
.settle-input {
  width: 100%; border: 1rpx solid #e5e7eb; border-radius: 12rpx;
  /* 修复：input 给定固定高度，避免挤压变形 */
  height: 80rpx; padding: 0 24rpx; font-size: 28rpx; color: #1a1a1a; box-sizing: border-box;
}
.settle-amount-row { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; }
.settle-amount { font-size: 36rpx; font-weight: 700; color: #22c55e; }
.settle-amount-tip { font-size: 22rpx; color: #bbb; }
.settle-actions { display: flex; gap: 24rpx; margin-top: 40rpx; }
.settle-cancel {
  flex: 1; text-align: center; padding: 28rpx 0; border-radius: 16rpx;
  background: #f3f4f6; color: #666; font-size: 30rpx;
}
.settle-confirm {
  flex: 2; text-align: center; padding: 28rpx 0; border-radius: 16rpx;
  background: #8766F3; color: #fff; font-size: 30rpx; font-weight: 600;
}
.settle-confirm.disabled { opacity: 0.6; }

/* 拒绝原因 */
.reject-reason {
  background: #fff5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}
.reject-label { font-size: 26rpx; color: #e74c3c; font-weight: 500; }
.reject-text { font-size: 28rpx; color: #555; line-height: 1.7; margin-top: 8rpx; display: block; }

/* 加载 */
.loading-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 100vh;
}
.loading-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.loading-text { font-size: 30rpx; color: #888; }
