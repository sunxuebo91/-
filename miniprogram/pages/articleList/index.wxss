.page {
  min-height: 100vh;
  background: #f6f6f6;
  padding: 24rpx;
  box-sizing: border-box;
}

.filters {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.search-icon-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1f2937;
}


.search-placeholder {
  color: #9ca3af;
}

.clear {
  color: #9ca3af;
  font-size: 28rpx;
  padding-left: 16rpx;
}

.tag-scroll {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
  padding: 12rpx 0;
  white-space: nowrap;
}

.tag-list {
  display: flex;
  padding: 0 16rpx;
  gap: 12rpx;
}

.tag-chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  box-sizing: border-box;
}

.tag-chip.active {
  background: #8b5cf6;
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(139, 92, 246, 0.25);
}

.articles-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.article-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.cover-wrapper {
  position: relative;
  width: 100%;
  height: 240rpx;
}

.article-card .cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background: #f2f2f2;
}

.tag-overlay {
  position: absolute;
  top: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.tag-overlay-item {
  padding: 8rpx 16rpx;
  border-radius: 0 0 0 12rpx;
  background: rgba(139, 92, 246, 0.95);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  backdrop-filter: blur(8rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.tag-overlay-item:first-child {
  border-radius: 0 16rpx 0 12rpx;
}

.info {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
  min-height: 80rpx;
}

.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-left {
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-right {
  color: #8b5cf6;
}

.load-tip {
  grid-column: 1 / -1;
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
  padding: 20rpx 0 10rpx;
}

.empty {
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
  margin-top: 80rpx;
}

/* Skeleton */
.skeleton {
  position: relative;
  overflow: hidden;
}

.skeleton-block {
  background: linear-gradient(90deg, #f2f2f2 25%, #f8f8f8 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: shimmer 1.4s ease infinite;
  border-radius: 12rpx;
}

.skeleton .cover {
  width: 100%;
  height: 240rpx;
}

.skeleton .info {
  padding: 16rpx;
}

.skeleton .title {
  height: 40rpx;
  margin-bottom: 16rpx;
}

.skeleton .meta {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.skeleton .meta-left {
  width: 40%;
  height: 28rpx;
}

.skeleton .meta-right {
  width: 30%;
  height: 28rpx;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
