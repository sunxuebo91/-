page {
  background: #FFF5F8;
  min-height: 100vh;
}

.page {
  padding: 24rpx 24rpx 60rpx;
}

/* Hero 头部 */
.hero {
  position: relative;
  border-radius: 28rpx;
  padding: 44rpx 36rpx 36rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 157, 0.28);
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #FF8FB1 0%, #FF6B9D 50%, #FFA8C5 100%);
  z-index: 0;
}

.hero-bg::before,
.hero-bg::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.hero-bg::before {
  width: 240rpx;
  height: 240rpx;
  top: -80rpx;
  right: -60rpx;
}

.hero-bg::after {
  width: 160rpx;
  height: 160rpx;
  bottom: -40rpx;
  left: -30rpx;
}

.hero-badge,
.hero-title,
.hero-sub,
.hero-stats {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.hero-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 20rpx;
  backdrop-filter: blur(8rpx);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.4);
}

/* 分类区块 */
.section {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 157, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.section-head-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.section-head-icon {
  font-size: 56rpx;
  line-height: 1;
}

.section-head-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 4rpx;
  letter-spacing: 2rpx;
}

.section-head-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section-head-count {
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.28);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.section-body {
  padding: 12rpx 24rpx 20rpx;
}

.item-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 22rpx 8rpx;
  border-bottom: 1rpx solid #f5f0f3;
}

.item-row:last-child {
  border-bottom: none;
}

.item-dot {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.item-dot-text {
  font-size: 24rpx;
  font-weight: 800;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.item-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

/* 底部贴士 */
.bottom-note {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-top: 8rpx;
}

.note-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.note-item {
  font-size: 24rpx;
  color: #777;
  line-height: 2;
}

.note-strong {
  color: #FF6B9D;
  font-weight: 700;
}

.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #c89aae;
  margin-top: 32rpx;
  letter-spacing: 2rpx;
}
