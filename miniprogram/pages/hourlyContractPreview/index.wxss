page {
  background: linear-gradient(180deg, #52C41A 0%, #73D13D 100%);
  min-height: 100vh;
}

.contract-preview {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: transparent;
  padding: 60rpx 32rpx 40rpx;
  position: relative;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.15));
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 操作按钮区域 */
.actions-container {
  padding: 0 32rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.action-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.15);
  transition: all 0.2s ease;
}

.action-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.2);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

/* 查看图标 - 转换为绿色 */
.view-icon {
  opacity: 1;
  filter: brightness(0) saturate(100%) invert(64%) sepia(98%) saturate(370%) hue-rotate(52deg) brightness(91%) contrast(87%);
}

/* 分享图标 - 转换为绿色 */
.share-icon {
  opacity: 1;
  filter: brightness(0) saturate(100%) invert(64%) sepia(98%) saturate(370%) hue-rotate(52deg) brightness(91%) contrast(87%);
}

.action-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #52C41A;
}

/* 分享按钮特殊样式 */
.share-card {
  background: rgba(255, 255, 255, 0.95);
  border: none;
  padding: 48rpx 32rpx;
  margin: 0;
  line-height: normal;
}

.share-card::after {
  border: none;
}

/* 信息容器 */
.info-container {
  padding: 0 32rpx;
}

/* 信息卡片 */
.info-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.15);
}

.info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

/* 提示卡片 */
.tips-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.15);
}

.tips-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #52C41A;
  margin-bottom: 20rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
}

