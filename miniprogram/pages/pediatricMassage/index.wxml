<view class="page">

  <!-- Hero -->
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-badge">国家中医药管理局推荐 · 循经辨证 · 安全无创</view>
    <view class="hero-title">小儿推拿指南</view>
    <view class="hero-sub">辨证施治 · 治未病 · 中医儿科</view>
    <view class="hero-stats">
      <view class="stat-item">
        <text class="stat-num">4</text>
        <text class="stat-label">个调理板块</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">28</text>
        <text class="stat-label">项常见处方</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">0-7</text>
        <text class="stat-label">岁适用年龄</text>
      </view>
    </view>
  </view>

  <!-- 图例 -->
  <view class="legend">
    <view class="legend-row">
      <view class="legend-tag">辨证施治</view>
      <view class="legend-tag">寒热分清</view>
      <view class="legend-tag">补泻有度</view>
      <view class="legend-tag">捏脊为基</view>
      <view class="legend-tag">治未病</view>
    </view>
    <text class="legend-text">参考国家中医药管理局《小儿推拿临床实践指南》、中华中医药学会儿科分会规范、张素芳主编《小儿推拿学》全国中医药行业规划教材、三字经派（青岛李德修）经典处方、海派（上海金义成）流派操作规范、湘西刘开运五经配伍法</text>
  </view>

  <!-- 时间轴：4 板块 -->
  <view class="timeline">
    <view class="tl-row" wx:for="{{phases}}" wx:key="title" wx:for-item="ph">
      <view class="tl-side">
        <view class="tl-dot">
          <text class="tl-dot-text">{{ph.dot}}</text>
        </view>
        <view class="tl-line" wx:if="{{index !== phases.length - 1}}"></view>
      </view>

      <view class="tl-card">
        <view class="tl-card-head">
          <view class="tl-age">{{ph.title}}</view>
          <view class="tl-hint">{{ph.hint}}</view>
          <view class="tl-feature">{{ph.feature}}</view>
        </view>

        <view class="task-block" wx:for="{{ph.items}}" wx:key="t" wx:for-item="it">
          <view class="task-title">
            <text class="task-sym">{{it.sym}}</text>
            <text class="task-tag">{{it.t}}</text>
          </view>
          <view class="task-desc">{{it.d}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部贴士 -->
  <view class="bottom-note">
    <view class="note-title">🌿 小儿推拿必读专业提醒</view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">👶</text><text class="tip-title">适用年龄与最佳时机</text></view>
      <view class="tip-desc">小儿推拿主推 0-7 岁（特定穴 6 岁内疗效最佳，7-12 岁需配合体穴）；3 月龄起即可日常保健；选饭前 30 分钟或饭后 1 小时操作，避免过饱过饥；患儿哭闹剧烈应暂停安抚后再做</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🤚</text><text class="tip-title">手法八字总诀</text></view>
      <view class="tip-desc">"轻、柔、平、稳、快、匀、实、透"——力度以皮肤微红、患儿不哭不抗拒为度；频率每分钟 200 次左右；每穴操作时间 1-3 分钟；总时长婴儿 10-15 分钟、幼儿 15-25 分钟为宜</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">⚖️</text><text class="tip-title">补泻分清</text></view>
      <view class="tip-desc">向心为补、离心为泻、来回为平；"补脾经、清大肠、补肾经、清肝经"等口诀严格遵守方向；寒证用"推三关"（温阳）、热证用"退六腑"（清热），二者剂量比常用 3:1（寒）或 1:3（热）</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🛡️</text><text class="tip-title">介质选择</text></view>
      <view class="tip-desc">爽身粉（一般保健）、婴儿润肤油（皮肤干燥）、薄荷水（风热感冒、高热）、生姜汁（风寒）、葱白汁（外感初起）；过敏体质先少量试用；皮肤破损、湿疹急性期禁用所有介质</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🚫</text><text class="tip-title">禁忌证清单</text></view>
      <view class="tip-desc">急腹症（阑尾炎、肠套叠、肠梗阻）、出血性疾病、骨折脱臼、严重心肺疾病、传染病急性期、皮肤局部感染溃疡烫伤、恶性肿瘤、严重营养不良——上述情况禁用或需在医师指导下进行</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🌡️</text><text class="tip-title">高热急症红色信号</text></view>
      <view class="tip-desc">体温 ≥ 39°C 持续不退 / 高热惊厥发作 / 颈项强直 / 喷射性呕吐 / 意识改变 / 皮肤瘀点瘀斑 / 呼吸急促 / 拒食拒饮——立即急诊就医，推拿不可代替西医急救</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🏫</text><text class="tip-title">流派选择</text></view>
      <view class="tip-desc">三字经派：取穴少（5-10 穴）、操作时间长（每穴 5-10 分钟）、推法为主，适合小婴儿；海派：取穴多、综合复式手法，适合复杂证；湘西刘氏：五经配伍、独穴重剂；家庭保健建议从三字经派入门</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🌡️</text><text class="tip-title">操作环境</text></view>
      <view class="tip-desc">室温 24-26°C 避免受凉；操作者修剪指甲、温暖双手、摘戒指；患儿穿着宽松薄衣或裸露施治部位；情绪安抚后开始；家长边操作边轻声哼唱或讲故事增加配合度</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">🤝</text><text class="tip-title">中西医结合</text></view>
      <view class="tip-desc">推拿作为辅助疗法对积食、便秘、腹泻、感冒初起、夜啼、汗证、保健效果较好；细菌感染、哮喘急性发作、严重脱水、惊厥等必须西医优先；建议确诊后再选择性配合推拿</view>
    </view>

    <view class="tip">
      <view class="tip-head"><text class="tip-icon">👩‍⚕️</text><text class="tip-title">个体化原则</text></view>
      <view class="tip-desc">本指南为通用辨证科普，先天性疾病、慢性病、过敏体质、特殊用药史儿童请咨询执业中医师；选择正规中医医院儿科或推拿科；警惕"包治百病""3 次见效"等夸大宣传</view>
    </view>
  </view>

  <view class="footer-tip">· 安得褓贝 · 用心陪伴每一天 ·</view>

  <transparent-share-fab
    page-title="小儿推拿指南"
    page-subtitle="常见症调理 + 四季保健"
    page-badge="中医循证 · 持证医师"
    theme-color="#C46B16"
    theme-color-light="#E8A55F"
    stats="{{[{num:'10+',label:'症状'},{num:'4',label:'季保健'},{num:'30',label:'分钟/次'}]}}"
    summary-lines="{{['常见症调理：感冒 / 咳嗽 / 厌食 / 便秘 / 腹泻 / 夜啼','基础保健方：捏脊 5 遍 + 摩腹 + 揉足三里','四季保健：春疏肝 / 夏清心 / 秋润肺 / 冬补肾','禁忌人群：高热惊厥 / 皮肤破损 / 急性感染','请由持证小儿推拿师操作，不替代正规诊疗']}}"
  />
</view>
