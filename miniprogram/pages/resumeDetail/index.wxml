<view class="page" wx:if="{{loaded}}">
  <!-- 顶部视频/图片区域 -->
  <view class="hero-wrap">
    <!-- 主媒体区：视频/图片切换显示 -->
    <block wx:if="{{detail.videoFileId && heroMediaType === 'video'}}">
      <video
        id="heroVideo"
        class="hero-video"
        src="{{detail.videoLocalSrc || detail.videoFileId}}"
        poster="{{detail.videoThumbSrc || detail.avatarSrc || detail.coverFileId || '/images/default-goods-image.png'}}"
        autoplay="{{false}}"
        loop="{{true}}"
        muted="{{heroVideoMuted}}"
        object-fit="cover"
        controls="{{false}}"
        show-progress="{{false}}"
        show-fullscreen-btn="{{false}}"
        show-play-btn="{{false}}"
        show-center-play-btn="{{false}}"
        enable-progress-gesture="{{false}}"
        enable-play-gesture="{{true}}"
        initial-time="0"
        show-loading="{{true}}"
        bindloadedmetadata="onHeroVideoLoaded"
        bindended="onHeroVideoEnded"
        binderror="onHeroVideoError"
        bindwaiting="onHeroVideoWaiting"
        bindcanplay="onHeroVideoCanPlay"
        bindprogress="onHeroVideoProgress"
      ></video>


      <!-- 播放按钮：使用普通 view（同层渲染支持） -->
      <view
        class="hero-video-center-play"
        wx:if="{{heroShowCenterPlayBtn}}"
        catchtap="onTapHeroCenterPlay"
      >
        <view class="hero-video-center-play__circle">
          <view class="hero-video-center-play__triangle"></view>
        </view>
      </view>

      <!-- 静音按钮：使用普通 view（同层渲染支持） -->
      <view class="hero-video-mute" catchtap="onTapHeroMute">
        <view class="hero-video-mute__text">
          {{heroVideoMuted ? '静音' : '开声'}}
        </view>
      </view>

      <!-- 加载提示：使用普通 view（同层渲染支持） -->
      <view class="hero-video-loading" wx:if="{{heroVideoLoading}}">
        <view class="hero-video-loading__spinner"></view>
        <view class="hero-video-loading__text">加载中...</view>
      </view>

    </block>

    <image
      wx:else
      class="hero-image"
      mode="aspectFill"
      src="{{heroSelectedImage || detail.coverFileId || '/images/default-goods-image.png'}}"
    ></image>








    <!-- 左上角：收藏信息 -->
    <view class="hero-top-left">
      <image class="mini-avatar" src="{{detail.avatarSrc || detail.coverFileId || '/images/default-goods-image.png'}}" mode="aspectFill"></image>

      <text class="collect-text">已有1562位用户收藏</text>
    </view>

    <!-- 右上角：编号 -->
    <view class="hero-top-right">
      <text class="resume-no">NO. {{detail.resumeNoText || '00000000'}}</text>
    </view>

    <!-- 底部小图轮播 -->
    <view class="hero-bottom-gallery" wx:if="{{(heroThumbPhotosPreview && heroThumbPhotosPreview.length) || detail.videoFileId}}">

      <view class="gallery-fixed-row">
        <!-- 视频入口：可切回视频（不另开窗口） -->
        <view
          class="gallery-item {{heroMediaType === 'video' ? 'is-active' : ''}}"
          wx:if="{{detail.videoFileId}}"
          bindtap="onTapHeroThumb"
          data-type="video"
        >
          <view class="gallery-thumb-wrap">
            <image class="gallery-thumb" src="{{detail.videoThumbSrc || detail.avatarSrc || detail.coverFileId || '/images/default-goods-image.png'}}" mode="aspectFill"></image>
            <view class="gallery-video-badge">视频</view>
          </view>
        </view>

        <!-- 中间固定展示 3 张：左右等距排布 -->
        <view
          class="gallery-item {{(heroMediaType === 'image' && heroSelectedImage === item.url) ? 'is-active' : ''}}"
          wx:for="{{heroThumbPhotosPreview}}"
          wx:key="url"
          bindtap="onTapHeroThumb"
          data-type="image"
          data-url="{{item.url}}"
        >
          <view class="gallery-thumb-wrap">
            <image class="gallery-thumb" src="{{item.url}}" mode="aspectFill"></image>
            <view class="gallery-video-badge" wx:if="{{item.category}}">{{item.category}}</view>
          </view>
        </view>

        <!-- 查看全部按钮（右侧固定不动） -->
        <view class="gallery-view-all" bindtap="onTapViewAllPhotos">
          <text class="gallery-view-all__text">查看全部</text>
          <text class="gallery-view-all__count">({{heroTotalMediaCount}})</text>
        </view>
      </view>
    </view>

  </view>

  <!-- 信息卡片（全宽） -->
  <view class="info-card">
    <!-- 头像和基本信息 -->
    <view class="profile-header">
      <view class="avatar-wrap">
        <view class="avatar-badge-wrap">
          <image class="avatar" src="{{detail.avatarSrc || detail.coverFileId || '/images/default-goods-image.png'}}" mode="aspectFill"></image>

          <!-- 月嫂等级：覆盖在头像下沿（你画的红框位置） -->
          <view class="avatar-level-pill" wx:if="{{detail.maternityNurseLevelText}}">{{detail.maternityNurseLevelText}}</view>
        </view>
      </view>


      <view class="profile-info">
        <view class="profile-info-grid">
          <text class="name">{{detail.name || '未命名'}}</text>
          <view class="jobtype-pill" wx:if="{{detail.jobTypeText}}">{{detail.jobTypeText}}</view>
          <text class="experience">{{detail.experienceYears || 0}}年经验</text>
          <text class="rating">{{detail.positiveReviewCount || 0}}个好评</text>
        </view>
      </view>

      <view class="verify-badge verify-badge--float">
        <text class="verify-badge__icon">✓</text>
        <text class="verify-badge__text">多重认证 严格筛查</text>
      </view>
    </view>



    <!-- 基本信息行：属相丨年龄丨星座丨籍贯（省市）丨民族丨学历（单行） -->
    <view class="basic-info-row">
      <view
        class="basic-info-cell {{index === detail.basicInfoItems.length - 1 ? 'is-last' : ''}}"
        wx:for="{{detail.basicInfoItems}}"
        wx:key="index"
      >{{item}}</view>
    </view>






  </view>

  <view class="content-inner">
  <!-- 获得证书 -->
  <view class="section" wx:if="{{certTicketsAll && certTicketsAll.length}}">
    <view class="section-title">获得证书：</view>

    <view class="cert-tickets">
      <scroll-view class="cert-tickets__scroll" scroll-x show-scrollbar="{{false}}">
        <view class="cert-tickets__scroll-row">
          <view
            class="cert-ticket"
            wx:for="{{certTicketsAll}}"
            wx:key="code"
          >
            <image class="cert-ticket__bg" src="/images/cert-card-bg.png" mode="widthFix"></image>
            <text class="cert-ticket__text">{{item.text}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 自我介绍 -->
  <view class="section" wx:if="{{detail.intro}}">
    <view class="section-title-with-icon">
      <image class="section-icon" src="/images/icons/info-circle.svg" mode="aspectFit"></image>
      <text class="section-title-text">自我介绍</text>
    </view>
    <view class="intro">{{detail.intro}}</view>
  </view>

  <!-- 推荐理由标签 -->
  <view class="section" wx:if="{{detail.recommendationTags && detail.recommendationTags.length > 0}}">
    <view class="section-title-with-icon">
      <image class="section-icon" src="/images/icons/thumbs-up.svg" mode="aspectFit"></image>
      <text class="section-title-text">推荐理由</text>
    </view>

    <view class="recommendation-tags">
      <view
        class="recommendation-tag {{item._isTop ? 'recommendation-tag--top' : ''}}"
        wx:for="{{recommendationVisibleTags}}"
        wx:key="_rank"
        style="grid-column: span {{item._gridSpan || 4}};"
        bindtap="onTapRecommendationTag"
        data-tag="{{item.tag}}"
        data-count="{{item.count}}"
        hover-class="recommendation-tag--pressed"
        hover-stay-time="80"
      >
        <text class="tag-text">{{item.tag}}</text>
        <text class="tag-count-badge" wx:if="{{item.count !== undefined && item.count !== null && item.count !== ''}}">{{item.count}}</text>
      </view>
    </view>

    <view
      class="recommendation-toggle"
      wx:if="{{recommendationHasMore}}"
      bindtap="onToggleRecommendationTags"
      hover-class="recommendation-toggle--pressed"
      hover-stay-time="80"
    >
      <text class="recommendation-toggle__text">{{recommendationExpanded ? '收起' : '展开全部'}}</text>
      <text class="recommendation-toggle__count">（{{recommendationExpanded ? '共' + recommendationTotalCount + '条' : '还有' + recommendationHiddenCount + '条'}}）</text>
    </view>
  </view>
  <view class="section" wx:elif="{{detail.intro}}">
    <view class="section-title-with-icon">
      <image class="section-icon" src="/images/icons/thumbs-up.svg" mode="aspectFit"></image>
      <text class="section-title-text">推荐理由</text>
    </view>
    <view class="no-recommendation-tags">暂无推荐理由</view>
  </view>

  <!-- 工作经历 -->
  <view class="section" wx:if="{{detail.workExperiences && detail.workExperiences.length}}">
    <view class="section-title-with-icon">
      <image class="section-icon" src="/images/icons/work-experience.svg" mode="aspectFit"></image>
      <text class="section-title-text">工作经历</text>
    </view>

    <view class="work-item" wx:for="{{detail.workExperiences}}" wx:key="index">
      <!-- 顶部标题行：月嫂 + 日期 | 订单编号 -->
      <view class="work-header">
        <!-- 左侧：月嫂标签 + 日期 -->
        <view class="work-period">
          <image class="period-icon" src="data:image/svg+xml;base64,"></image>
          <text class="period-text">月嫂</text>
          <text class="period-date">{{item.startDate || '—'}}-{{item.endDate || '至今'}}</text>
        </view>

        <!-- 右侧：订单编号 -->
        <view class="work-order-tag" wx:if="{{item.orderNumber}}">
          <text>订单编号：{{item.orderNumber}}</text>
        </view>
      </view>

      <!-- 客户信息行 -->
      <view class="work-customer-info">
        <!-- 客户姓名 -->
        <view class="customer-name" wx:if="{{item.customerName}}">
          <text class="name-icon">👤</text>
          <text>{{item.customerName}}</text>
        </view>

        <!-- 评分（暂时用5星展示） -->
        <view class="customer-rating">
          <text class="star">⭐</text>
          <text class="star">⭐</text>
          <text class="star">⭐</text>
          <text class="star">⭐</text>
          <text class="star">⭐</text>
        </view>

        <!-- 服务区域 -->
        <view class="service-area" wx:if="{{item.serviceArea}}">
          <image class="area-icon" src="data:image/svg+xml;base64,"></image>
          <text>{{item.serviceArea}}</text>
        </view>
      </view>

      <!-- 工作照片横向滚动 -->
      <view class="work-photos-scroll" wx:if="{{item.workPhotos && item.workPhotos.length}}">
        <scroll-view class="work-photos-scroll__view" scroll-x show-scrollbar="{{false}}">
          <view class="work-photos-scroll__row">
            <view
              class="work-photo-card"
              wx:for="{{item.workPhotos}}"
              wx:for-item="photo"
              wx:key="photo"
            >
              <image
                class="work-photo-card__img"
                src="{{photo}}"
                mode="aspectFill"
                bindtap="onPreviewWorkPhoto"
                binderror="onWorkPhotoError"
                data-urls="{{item.workPhotos}}"
                data-current="{{photo}}"
                show-menu-by-longpress
              ></image>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 工作描述 -->
      <view class="work-description" wx:if="{{item.description}}">
        <text class="desc-text">{{item.description}}</text>
      </view>

      <!-- 客户评价 -->
      <view class="work-review-box" wx:if="{{item.customerReview}}">
        <view class="review-header">
          <text class="review-icon">💬</text>
          <text class="review-title">客户评价</text>
        </view>
        <view class="review-text">{{item.customerReview}}</view>
      </view>
    </view>
  </view>

  <!-- 员工评价 -->
  <view class="section" wx:if="{{(evaluations.statistics && evaluations.statistics.totalCount > 0) || (evaluations.list && evaluations.list.length)}}">
    <view class="section-title-with-icon">
      <image class="section-icon" src="/images/icons/star.svg" mode="aspectFit"></image>
      <text class="section-title-text">员工评价</text>
    </view>

    <!-- 评价统计 -->
    <view class="evaluation-stats" wx:if="{{evaluations.statistics && evaluations.statistics.totalCount > 0}}">
      <view class="stats-main">
        <view class="stats-score">
          <text class="score-number">{{evaluations.statistics.averageRating || 0}}</text>
          <text class="score-total">/5.0</text>
        </view>
        <view class="stats-stars">
          <text class="star {{evaluations.statistics.averageRating >= 1 ? 'filled' : ''}}">⭐</text>
          <text class="star {{evaluations.statistics.averageRating >= 2 ? 'filled' : ''}}">⭐</text>
          <text class="star {{evaluations.statistics.averageRating >= 3 ? 'filled' : ''}}">⭐</text>
          <text class="star {{evaluations.statistics.averageRating >= 4 ? 'filled' : ''}}">⭐</text>
          <text class="star {{evaluations.statistics.averageRating >= 5 ? 'filled' : ''}}">⭐</text>
        </view>
        <text class="stats-count">共{{evaluations.statistics.totalCount || 0}}条评价</text>
      </view>

      <view class="stats-details">
        <view class="stats-item">
          <text class="stats-label">服务态度</text>
          <text class="stats-value">{{evaluations.statistics.averageServiceAttitude || 0}}</text>
        </view>
        <view class="stats-item">
          <text class="stats-label">专业技能</text>
          <text class="stats-value">{{evaluations.statistics.averageProfessionalSkill || 0}}</text>
        </view>
        <view class="stats-item">
          <text class="stats-label">工作效率</text>
          <text class="stats-value">{{evaluations.statistics.averageWorkEfficiency || 0}}</text>
        </view>
        <view class="stats-item">
          <text class="stats-label">沟通能力</text>
          <text class="stats-value">{{evaluations.statistics.averageCommunication || 0}}</text>
        </view>
      </view>
    </view>

    <!-- 评价列表 -->
    <view class="evaluation-list">
      <view class="evaluation-item" wx:for="{{evaluations.list}}" wx:key="_id">
        <view class="eval-header">
          <view class="eval-user">
            <text class="user-icon">👤</text>
            <text class="user-name">{{item.evaluatorName || '匿名用户'}}</text>
          </view>
          <view class="eval-rating">
            <text class="rating-number">{{item.overallRating}}</text>
            <text class="star">⭐</text>
          </view>
        </view>

        <view class="eval-tags" wx:if="{{item.tags && item.tags.length}}">
          <text class="eval-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="tag">{{tag}}</text>
        </view>

        <view class="eval-comment" wx:if="{{item.comment}}">
          <text>{{item.comment}}</text>
        </view>

        <view class="eval-footer">
          <text class="eval-date">{{item.createdAtText || ''}}</text>
          <text class="eval-type">{{item.evaluationTypeText || ''}}</text>
        </view>
      </view>
    </view>

    <!-- 查看更多评价 -->
    <view class="view-more-evaluations" wx:if="{{evaluations.hasMore}}" bindtap="onViewMoreEvaluations">
      <text>查看更多评价</text>
      <text class="arrow">→</text>
    </view>
  </view>

  <view class="safe-tip">安得褓贝提示：信息仅供参考，具体服务以沟通确认结果为准。</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar is-single">
    <view class="bar-btn primary" bindtap="onTapConsult">咨询</view>
  </view>

</view>


<view class="loading" wx:if="{{!loaded}}">加载中...</view>
