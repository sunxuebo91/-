<view class="page">
  <view class="header-card">
    <view class="header-content" bindtap="goLogin">
      <image class="avatar" src="{{me.avatar || me.avatarUrl || '/images/icons/avatar.png'}}"></image>
      <view class="user-info">
        <view class="nickname">{{me.nickname || me.phone || '立即登录'}}</view>
      </view>
    </view>
    <view class="edit-btn" catchtap="onTapSettings">
      <text class="edit-text">资料修改</text>
    </view>
  </view>


  <!-- 员工功能区 -->
  <view class="section" wx:if="{{me.role === 'staff'}}">
    <view class="section-title">员工功能</view>
    <view class="menu-item" bindtap="goResumeManage">
      <view class="menu-label">简历管理</view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 我的服务：图标宫格 -->
  <view class="section service-section">
    <view class="section-title">我的服务</view>
    <view class="service-grid">
      <view class="service-item" bindtap="goMyOrders" wx:if="{{me.role !== 'staff' && me.phone}}">
        <view class="service-icon-wrap service-icon-order">
          <image class="service-icon-img" src="/images/icons/my-orders.svg" mode="aspectFit"/>
        </view>
        <text class="service-label">我的订单</text>
      </view>
      <view class="service-item" bindtap="goBabyDiary">
        <view class="service-icon-wrap service-icon-diary">
          <image class="service-icon-img" src="/images/icons/baby-diary.svg" mode="aspectFit"/>
        </view>
        <text class="service-label">宝贝日记</text>
      </view>
    </view>
  </view>

  <view class="section">

    <view class="menu-item contact-menu-item">
      <view class="menu-label">联系客服</view>
      <view class="menu-arrow">›</view>
      <!-- 透明按钮覆盖整行：未登录仅走 bindtap；已登录时 open-type=contact 打开客服 -->
      <button class="contact-menu-btn" open-type="{{isLoggedIn ? 'contact' : ''}}" bindtap="onContactTap" bindcontact="handleContact" hover-class="none"></button>
    </view>

    <view class="menu-item" bindtap="onTapHelp">
      <view class="menu-label">帮助</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="onTapSettings">
      <view class="menu-label">设置</view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="section" wx:if="{{me.phone || me.nickname}}">
    <view class="menu-item logout-item" bindtap="onLogout">
      <view class="menu-label logout-label">退出登录</view>
    </view>
  </view>

</view>

