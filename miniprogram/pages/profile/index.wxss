page {
  background: linear-gradient(180deg, #8766F3 0%, #A694FF 100%);
}

.page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 员工订阅提醒横幅 */
.subscribe-banner {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #f0ebff 0%, #e8e0ff 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid rgba(135, 102, 243, 0.2);
}

.subscribe-banner-content {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.subscribe-banner-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.subscribe-banner-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.subscribe-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8766F3;
}

.subscribe-banner-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.subscribe-banner-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.subscribe-btn {
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  border-radius: 32rpx;
  padding: 14rpx 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  line-height: 1;
}

.subscribe-btn::after {
  border: none;
}

.subscribe-dismiss {
  font-size: 24rpx;
  color: #aaa;
}

/* 顶部用户卡片 */
.header-card {
  background: linear-gradient(180deg, #8766F3 0%, #A694FF 100%);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #fff;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.staff-badge {
  position: absolute;
  left: 50%;
  bottom: -18rpx;
  transform: translateX(-50%);
  padding: 4rpx 14rpx;
  background: linear-gradient(135deg, #FFB547 0%, #FF8A3D 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  border-radius: 16rpx;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(255, 138, 61, 0.4);
  white-space: nowrap;
  letter-spacing: 1rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.edit-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 32rpx;
  backdrop-filter: blur(10rpx);
}

.edit-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.role-tag {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 区块 */
.section {
  background: #fff;
  margin: 24rpx;
  padding: 0 32rpx;
  border-radius: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8766F3;
  padding: 24rpx 0 0 0;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.phone-input {
  flex: 1;
  background: #f6f6f6;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.save-btn {
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  border-radius: 8rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  line-height: 1;
  box-shadow: var(--ui-shadow-brand);
}

.hint-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  line-height: 1.5;
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 联系客服：用透明按钮覆盖整行，避免 button 默认样式导致“变形” */
.contact-menu-item {
  position: relative;
}

.contact-menu-btn {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 0;
  opacity: 0;
}

.contact-menu-btn::after {
  border: none;
}

/* 重置 button 样式 */
.menu-button {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  text-align: left;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-button::after {
  border: none;
}

.menu-item:first-child {
  padding-top: 24rpx;
}

.menu-item:last-child {
  border-bottom: none;
  padding-bottom: 24rpx;
}

.menu-label {
  font-size: 32rpx;
  color: #333;
}

.menu-arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
}

/* 我的服务 图标宫格 */
.service-section {
  padding: 0 32rpx 32rpx;
}
.service-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding-top: 24rpx;
}
.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 0 0 25%;
  width: 25%;
  margin-bottom: 24rpx;
  gap: 14rpx;
}
.service-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.service-icon-order   { background: #EDE8FF; }
.service-icon-diary   { background: #FFF0E8; }
.service-icon-referral{ background: #E8F9EE; }
.service-icon-poster  { background: #EDE8FF; }
.service-icon-salary  { background: #E8F5FF; }
.service-icon-img {
  width: 60rpx;
  height: 60rpx;
}
.service-label {
  font-size: 24rpx;
  color: #333;
}

/* 推荐图标角标 */
.service-icon-wrap {
  position: relative;
}
.referral-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #f04a4a;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  z-index: 1;
}
.referral-badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}



/* 微信头像昵称授权按钮 */
.wx-profile-btn {
  margin-top: 14rpx;
  margin-left: 0;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.wx-profile-btn::after {
  border: none;
}

/* 微信客服按钮（伪装成菜单项） */
.menu-btn {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  line-height: 1;
}

.menu-btn::after {
  border: none;
}

/* 退出登录按钮 */
.logout-item {
  justify-content: center;
}

.logout-label {
  color: #e74c3c;
  font-weight: 600;
  text-align: center;
}

/* 调试区域 */
.debug-section {
  margin: 24rpx;
  padding: 24rpx;
  background: #fff3cd;
  border-radius: 12rpx;
  border: 2rpx dashed #ffc107;
}

.debug-btn {
  width: 100%;
  height: 80rpx;
  background: #ffc107;
  color: #333;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0;
  padding: 0;
}

.debug-btn::after {
  border: none;
}
