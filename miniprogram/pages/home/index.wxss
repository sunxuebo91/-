page {
  background: #f7f7fb;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.home {
  min-height: 100vh;
}

/* 顶部渐变：Banner 区域 */
.top {
  padding: 24rpx 0 40rpx;
  background: radial-gradient(1200rpx 600rpx at 20% -10%, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 60%),
    linear-gradient(135deg, rgba(135, 102, 243, 1) 0%, rgba(166, 148, 255, 1) 100%);
}

.banner-wrap {
  padding: 0 24rpx;
}

/* Banner 轮播图样式 */
.banner-swiper {
  width: 100%;
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: var(--ui-shadow-card);
}

.banner-item {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 渐变占位样式（无图片时显示） */
.banner-placeholder-gradient {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-content {
  text-align: center;
  color: #ffffff;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 白底内容：只保留三个入口 */
.content {
  margin-top: -16rpx;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 28rpx 24rpx 34rpx;
}

.quick-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 0;
  border-radius: 20rpx;
  background: #faf9ff;
}

.quick-btn:active {
  transform: scale(0.98);
}

.quick-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(17, 24, 39, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
}

.quick-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.quick-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 700;
}

/* 保姆 - 橙色系背景，匹配橙红色图标 */
.bg-1 { background: linear-gradient(135deg, #FFE8E0 0%, #FFD4C4 100%); }
/* 月嫂 - 紫色系背景，匹配紫色图标 */
.bg-2 { background: linear-gradient(135deg, #EDE7FF 0%, #DDD2FF 100%); }
/* 育儿嫂 - 粉色系背景，匹配粉红色图标 */
.bg-3 { background: linear-gradient(135deg, #FFE8F0 0%, #FFD6E5 100%); }
/* 护老 - 橙黄色系背景，匹配橙黄色图标 */
.bg-4 { background: linear-gradient(135deg, #FFF4E6 0%, #FFE8CC 100%); }

/* 育儿宝典模块 */
.articles-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.title-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 32rpx;
  font-weight: 300;
}

/* 文章网格布局 */
.articles-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

/* 文章卡片 */
.article-card {
  background: var(--ui-surface);
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid var(--ui-border);
  box-shadow: var(--ui-shadow-card);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.article-card:active {
  transform: translateY(2rpx) scale(0.99);
  box-shadow: 0 8rpx 20rpx rgba(17, 24, 39, 0.06);
}

/* 文章封面 */
.article-cover {
  width: 100%;
  height: 200rpx;
  background: #e0e0e0;
  display: block;
}

/* 文章信息 */
.article-info {
  padding: 16rpx;
}

.article-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 72rpx;
  margin-bottom: 8rpx;
}

.article-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 20rpx;
  color: #999;
}

.article-author {
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-views {
  flex-shrink: 0;
  color: #999;
  font-size: 20rpx;
}


