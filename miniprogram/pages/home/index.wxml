<view class="home">
  <!-- 顶部渐变背景：Banner 轮播 -->
  <view class="top">
    <view class="banner-wrap">
      <!-- Banner骨架屏 -->
      <view wx:if="{{bannerList.length === 0}}" class="banner-skeleton">
        <view class="skeleton-shimmer"></view>
      </view>

      <!-- Banner轮播 -->
      <swiper
        wx:else
        class="banner-swiper"
        indicator-dots="{{indicatorDots}}"
        autoplay="{{autoplay}}"
        interval="{{interval}}"
        duration="{{duration}}"
        circular="{{true}}"
        indicator-color="rgba(255,255,255,0.5)"
        indicator-active-color="#ffffff"
      >
        <swiper-item wx:for="{{bannerList}}" wx:key="_id" bindtap="onBannerTap" data-item="{{item}}">
          <view class="banner-item">
            <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
          </view>
        </swiper-item>
      </swiper>
    </view>
  </view>

  <!-- 四个入口：保姆 / 月嫂 / 育儿嫂 / 护老 -->
  <view class="content">
    <view class="quick-row">
      <view class="quick-btn" bindtap="goResumeList" data-jobtype="baomu">
        <view class="quick-icon bg-1">
          <image class="quick-icon-img" src="/images/icons/baomu.svg" mode="aspectFit"></image>
        </view>
        <text class="quick-text">保姆</text>
      </view>
      <view class="quick-btn" bindtap="goResumeList" data-jobtype="yuesao">
        <view class="quick-icon bg-2">
          <image class="quick-icon-img" src="/images/icons/yuexin.svg" mode="aspectFit"></image>
        </view>
        <text class="quick-text">月嫂</text>
      </view>
      <view class="quick-btn" bindtap="goResumeList" data-jobtype="yuer">
        <view class="quick-icon bg-3">
          <image class="quick-icon-img" src="/images/icons/yuer.svg" mode="aspectFit"></image>
        </view>
        <text class="quick-text">育儿嫂</text>
      </view>
      <view class="quick-btn" bindtap="goResumeList" data-jobtype="hulao">
        <view class="quick-icon bg-4">
          <image class="quick-icon-img" src="/images/icons/hulao.svg" mode="aspectFit"></image>
        </view>
        <text class="quick-text">护老</text>
      </view>
    </view>

    <!-- 透明服务和答疑解惑卡片 -->
    <view class="service-cards">
      <view class="service-card service-card-blue" bindtap="goTransparentService">
        <view class="service-card-content">
          <view class="service-card-title">透明服务</view>
          <view class="service-card-subtitle">价格透明 服务透明</view>
        </view>
        <image class="service-card-image" src="/images/icons/transparent-service.svg" mode="aspectFit"></image>
      </view>
      <view class="service-card service-card-green" bindtap="goQA">
        <view class="service-card-content">
          <view class="service-card-title">答疑解惑</view>
          <view class="service-card-subtitle">专业解答 贴心服务</view>
        </view>
        <image class="service-card-image" src="/images/icons/qa-service.svg" mode="aspectFit"></image>
      </view>
    </view>

    <!-- 宝贝日记入口（仅 staff） -->
    <view class="diary-entry-card" wx:if="{{showBabyDiaryEntry}}" bindtap="goBabyDiary">
      <view class="diary-left">
        <view class="diary-icon">
          <image class="diary-icon-img" src="/images/icons/baby-diary.svg" mode="aspectFit"></image>
        </view>
        <view class="diary-info">
          <view class="diary-title">宝贝日记</view>
          <view class="diary-subtitle">记录宝宝成长每一天</view>
        </view>
      </view>
      <view class="diary-right">
        <view class="diary-badge" wx:if="{{todayDiaryCount > 0}}">今日已记录 {{todayDiaryCount}} 条</view>
        <text class="diary-arrow">›</text>
      </view>
    </view>

    <!-- 女性力量海报入口 -->
    <view class="poster-entry-card" bindtap="goPoster">
      <view class="poster-entry-left">
        <text class="poster-entry-icon">💫</text>
        <view class="poster-entry-info">
          <view class="poster-entry-title">女性力量 · 每日海报</view>
          <view class="poster-entry-sub">情感 / 事业 / 创业 / 经济独立</view>
        </view>
      </view>
      <text class="poster-entry-arrow">›</text>
    </view>

    <!-- 褓贝分享模块 -->
    <view class="articles-section">

      <view class="section-header">
        <view class="section-title">
          <image class="title-icon" src="/images/icons/baobei-share.svg" mode="aspectFit"></image>
          <text class="title-text">褓贝分享</text>
        </view>
        <view class="section-more" bindtap="goArticleList">
          <text>更多</text>
          <text class="arrow">›</text>
        </view>
      </view>





      <!-- 文章加载中骨架屏 -->
      <view class="articles-grid" wx:if="{{articlesLoading}}">
        <view class="article-card article-skeleton" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
          <view class="skeleton-cover"></view>
          <view class="article-info">
            <view class="skeleton-title"></view>
            <view class="skeleton-footer">
              <view class="skeleton-text"></view>
              <view class="skeleton-text"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 文章列表 -->
      <view class="articles-grid" wx:elif="{{articles && articles.length > 0}}">
        <view
          class="article-card"
          wx:for="{{articles}}"
          wx:key="_id"
          bindtap="goArticleDetail"
          data-id="{{item._id}}"
        >
          <!-- 文章封面图 -->
          <image
            class="article-cover"
            src="{{item.coverImage || '/images/default-goods-image.png'}}"
            mode="aspectFill"
            lazy-load="{{true}}"
          ></image>

          <!-- 文章信息 -->
          <view class="article-info">
            <view class="article-title">{{item.title}}</view>
            <view class="article-footer">
              <text class="article-author">{{item.author}}</text>
              <text class="article-views">{{item.viewCount}}阅读</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 无数据提示 -->
      <view wx:else style="padding: 40rpx; text-align: center; color: #999;">
        <text>暂无文章</text>
      </view>
    </view>
  </view>
</view>



