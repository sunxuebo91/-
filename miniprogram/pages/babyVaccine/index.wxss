page {
  background: #F1FBF6;
  min-height: 100vh;
}

.page {
  padding: 24rpx 24rpx 60rpx;
}

/* Hero */
.hero {
  position: relative;
  border-radius: 28rpx;
  padding: 44rpx 36rpx 36rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(61, 190, 139, 0.28);
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #3DBE8B 0%, #5FD4A0 50%, #7DE5B8 100%);
  z-index: 0;
}

.hero-bg::before,
.hero-bg::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.hero-bg::before {
  width: 240rpx;
  height: 240rpx;
  top: -80rpx;
  right: -60rpx;
}

.hero-bg::after {
  width: 160rpx;
  height: 160rpx;
  bottom: -40rpx;
  left: -30rpx;
}

.hero-badge,
.hero-title,
.hero-sub,
.hero-stats {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.hero-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.4);
}

/* 图例 */
.legend {
  display: flex;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.legend-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

.legend-tag-free { background: #E8F8EF; color: #3DBE8B; }
.legend-tag-paid { background: #FFF3E0; color: #FF9500; }

.legend-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

/* 时间轴 */
.timeline {
  padding: 0;
}

.tl-row {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.tl-side {
  width: 88rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tl-dot {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #5FD4A0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(95, 212, 160, 0.35);
  flex-shrink: 0;
}

.tl-dot-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #3DBE8B;
  letter-spacing: 1rpx;
}

.tl-line {
  flex: 1;
  width: 4rpx;
  background: linear-gradient(to bottom, #5FD4A0, #C8F0DC);
  margin: 8rpx 0;
  min-height: 24rpx;
}

.tl-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
  min-width: 0;
}

.tl-card-head {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed #e8efeb;
}

.tl-age {
  font-size: 32rpx;
  font-weight: 800;
  color: #2c2c2c;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.tl-hint {
  font-size: 22rpx;
  color: #999;
}

.tl-group-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tl-group-head-paid {
  margin-top: 16rpx;
}

.tl-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.tl-tag-free { background: #E8F8EF; color: #3DBE8B; }
.tl-tag-paid { background: #FFF3E0; color: #FF9500; }

.tl-group-title {
  font-size: 22rpx;
  color: #888;
}

.tl-vac {
  background: #F8FBF9;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 8rpx;
  border-left: 4rpx solid #5FD4A0;
}

.tl-vac:last-child { margin-bottom: 0; }

.tl-vac-paid {
  background: #FFFBF3;
  border-left-color: #FF9500;
}

.tl-vac-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.tl-vac-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #2c2c2c;
  flex: 1;
  min-width: 0;
}

.tl-vac-dose {
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
}

.tl-vac-dose-free { color: #3DBE8B; }
.tl-vac-dose-paid { color: #FF9500; }

.tl-vac-protect {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
}

/* 底部贴士 */
.bottom-note {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-top: 8rpx;
}

.note-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.note-item {
  font-size: 24rpx;
  color: #777;
  line-height: 2;
}

.note-strong {
  color: #3DBE8B;
  font-weight: 700;
}

.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #8ec3a8;
  margin-top: 32rpx;
  letter-spacing: 2rpx;
}
