/* 页面容器 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  box-sizing: border-box;
}

/* 内容容器 */
.content {
  width: 100%;
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* 表单区域 */
.form-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

/* 表单控件容器：用容器的宽度统一约束 input/button */
.form-control {
  width: 364rpx;
  max-width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  display: block;
  margin: 0;
}

/* 按钮：覆盖微信小程序 button 的所有默认样式 */
.form-button {
  width: 100% !important;
  height: 88rpx !important;
  min-height: 88rpx !important;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%) !important;
  color: #fff !important;
  border-radius: 16rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  border: none !important;
  box-shadow: 0 4rpx 16rpx rgba(135, 102, 243, 0.3) !important;
  display: block !important;
  box-sizing: border-box !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 88rpx !important;
  text-align: center !important;
  overflow: visible !important;
}

.form-button::after {
  border: none !important;
}

/* 协议区域 */
.agreement {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  flex-wrap: wrap;
  justify-content: center;
}

.checkbox {
  margin-right: 8rpx;
  transform: scale(0.8);
}

.text {
  color: #666;
}

.link {
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  padding: 0 6rpx;
  text-decoration: underline;
}

/* 暂不登录 */
.skip-login {
  margin-top: 48rpx;
  font-size: 28rpx;
  color: #8766F3;
  text-align: center;
  padding: 20rpx 80rpx;
  border: 2rpx solid #c4b5fd;
  border-radius: 48rpx;
  background: #fff;
}