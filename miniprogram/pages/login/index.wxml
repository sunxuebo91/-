<view class="page">
  <view class="content">
    <!-- 表单区域 -->
    <view class="form-section">
      <!-- 昵称输入框（选填） -->
      <view class="form-control">
        <input type="nickname" class="form-input" placeholder="昵称（选填）" value="{{nickname}}" bindinput="onNicknameInput" />
      </view>

      <!-- 登录按钮 -->
      <view class="form-control">
        <button class="form-button" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          手机号快捷登录
        </button>
      </view>
    </view>

    <!-- 协议区域 -->
    <view class="agreement">
      <checkbox class="checkbox" checked="{{agreed}}" bindtap="toggleAgree" />
      <text class="text">我已阅读并同意</text>
      <text class="link" bindtap="openUserAgreement">《用户协议》</text>
      <text class="text">和</text>
      <text class="link" bindtap="openPrivacyPolicy">《隐私政策》</text>
    </view>

    <!-- 暂不登录（满足微信登录规范：必须提供可用的取消/跳过选项） -->
    <view class="skip-login" bindtap="onSkipLogin">暂不登录</view>
  </view>
</view>
