<view class="page">
  <view class="content">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{avatarUrl || me.avatarUrl || '/images/icons/avatar.png'}}"></image>
      <view class="avatar-tip">点击设置头像</view>
    </button>

    <view class="nickname-input">
      <input type="nickname" class="input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <button class="auth-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <view class="btn-text">手机号快捷登录</view>
    </button>

    <!-- 账号密码登录按钮 -->
    <button class="account-login-btn" bindtap="showAccountLoginModal">
      <view class="btn-text">账号密码登录</view>
    </button>

    <view class="agreement">
      <checkbox class="checkbox" checked="{{agreed}}" bindtap="toggleAgree" />
      <text class="text">我已阅读并同意</text>
      <text class="link" bindtap="openUserAgreement">《用户协议》</text>
      <text class="text">和</text>
      <text class="link" bindtap="openPrivacyPolicy">《隐私政策》</text>
    </view>

  </view>

  <!-- 账号密码登录弹窗 -->
  <view class="modal-mask" wx:if="{{showAccountModal}}" bindtap="hideAccountLoginModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">账号密码登录</view>
        <view class="modal-close" bindtap="hideAccountLoginModal">✕</view>
      </view>

      <view class="modal-body">
        <view class="form-item">
          <view class="form-label">账号</view>
          <input class="form-input" type="text" placeholder="请输入账号" value="{{username}}" bindinput="onUsernameInput" />
        </view>
        <view class="form-item">
          <view class="form-label">密码</view>
          <input class="form-input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
        </view>

        <button class="modal-login-btn" bindtap="onAccountLogin">
          <view class="btn-text">登录</view>
        </button>

        <view class="register-tip">
          <text class="tip-text">还没有账号？</text>
          <text class="register-link" bindtap="goRegister">立即注册</text>
        </view>
      </view>
    </view>
  </view>
</view>

