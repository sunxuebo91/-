<view class="page">
  <!-- 生成中：占位/旋转 -->
  <view class="loading-wrap" wx:if="{{generating || !posterPath}}">
    <view class="loading-spinner"></view>
    <view class="loading-text">海报生成中...</view>
    <view class="loading-sub">为你的姐妹定制专属薪资测评海报</view>
  </view>

  <!-- 海报预览（满屏展示）+ 操作区 -->
  <view class="poster-preview" wx:if="{{posterPath}}">
    <image class="poster-img" src="{{posterPath}}" mode="aspectFit" bindtap="onShowShare"></image>
    <view class="poster-actions">
      <view class="poster-btn poster-btn-primary" bindtap="onShowShare">分享给好友</view>
      <view class="poster-btn poster-btn-ghost" bindtap="onSaveAlbum">保存到相册</view>
    </view>
    <view class="poster-tip">扫码即可直达本测评，让她也来测一测</view>
  </view>

  <!-- 隐藏 Canvas（合成用） -->
  <canvas type="2d" id="poster-canvas" class="poster-canvas"></canvas>
</view>
