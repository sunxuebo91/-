<view class="page">
  <view class="section">
    <view class="section-title">个人信息</view>

    <view class="info-item">
      <view class="label">头像</view>
      <view class="value-wrapper">
        <image class="avatar" src="{{tempAvatarUrl || '/images/icons/avatar.png'}}"></image>
        <button class="edit-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <view class="edit-text">编辑</view>
        </button>
      </view>
    </view>

    <view class="info-item">
      <view class="label">昵称</view>
      <view class="value-wrapper">
        <input
          class="nickname-input"
          type="nickname"
          placeholder="请输入昵称"
          value="{{tempNickname}}"
          bindinput="onNicknameInput"
          bindblur="onNicknameBlur"
        />
      </view>
    </view>

    <view class="info-item">
      <view class="label">手机号<text class="required-mark">*</text></view>
      <view class="value-wrapper">
        <button wx:if="{{!me.phone}}" class="phone-auth-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          <view class="phone-text-btn">点击授权</view>
        </button>
        <view wx:else class="phone-text">{{me.phone}}</view>
      </view>
    </view>
  </view>

  <view class="btn-wrapper">
    <button class="save-btn" bindtap="onSave">保存修改</button>
  </view>

  <!-- 员工专属：简历查看提醒订阅 -->
  <view class="section" wx:if="{{me.role === 'staff'}}">
    <view class="section-title">消息提醒</view>
    <view class="info-item" bindtap="onManualSubscribe">
      <view class="label-full">
        <view class="menu-label">简历查看提醒</view>
        <view class="menu-sub">客户查看您分享的简历时通知您</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>
</view>

