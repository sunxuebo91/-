.page{min-height:100vh;background:#f6f6f6}
.topbar{padding:28rpx 24rpx 10rpx}
.title{font-size:36rpx;font-weight:800;color:#111}
.meta{margin-top:8rpx;color:#666;font-size:26rpx}
.scroll{height:calc(100vh - 160rpx)}

.section{margin:14rpx 20rpx 22rpx;background:#fff;border-radius:24rpx;padding:18rpx 18rpx 6rpx;box-shadow:0 10rpx 28rpx rgba(20,20,20,0.06)}
.section-title{font-size:30rpx;font-weight:900;color:#222;margin-bottom:8rpx}

.group{margin-top:16rpx;padding-top:10rpx;border-top:1rpx solid #f0f0f0}
.group-title{font-size:26rpx;font-weight:800;color:#333;margin-bottom:12rpx}
.grid{display:flex;flex-wrap:wrap;gap:14rpx}
.field{width:calc(50% - 7rpx)}
.field.full{width:100%}
.label{font-size:22rpx;color:#666;margin-bottom:8rpx}
.input{background:#f6f6f6;border-radius:16rpx;padding:18rpx 16rpx;font-size:28rpx;color:#111}
.picker{background:#f6f6f6;border-radius:16rpx;padding:18rpx 16rpx;font-size:28rpx;color:#111}

.radios,.checks{display:flex;flex-wrap:wrap;gap:16rpx}
.radio,.check{display:flex;align-items:center;gap:10rpx;background:#f6f6f6;padding:12rpx 14rpx;border-radius:999rpx;font-size:26rpx;color:#222}

.textarea{min-height:140rpx;background:#f6f6f6;border-radius:16rpx;padding:18rpx 16rpx;font-size:28rpx;color:#111;width:100%;box-sizing:border-box}

.photo-grid{display:flex;flex-wrap:wrap;gap:14rpx}
.photo{width:200rpx;height:200rpx;border-radius:18rpx;overflow:hidden;position:relative;background:#f6f6f6}
.photo-img{width:100%;height:100%}
.photo-del{position:absolute;right:10rpx;top:10rpx;width:42rpx;height:42rpx;border-radius:21rpx;background:rgba(0,0,0,0.55);color:#fff;display:flex;align-items:center;justify-content:center;font-size:28rpx}
.photo.add{display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8rpx;border:2rpx dashed rgba(139,92,246,0.35)}
.plus{font-size:52rpx;color:#8b5cf6;font-weight:800;line-height:52rpx}
.plus-text{font-size:24rpx;color:#6d28d9}

.bottom{position:fixed;left:0;right:0;bottom:0;padding:14rpx 20rpx 22rpx;background:linear-gradient(180deg,rgba(246,246,246,0) 0%,rgba(246,246,246,1) 40%)}
.hint{padding:0 6rpx 10rpx;color:#666;font-size:24rpx}
.actions{display:flex;gap:14rpx}
.btn{flex:1;text-align:center;padding:20rpx 0;border-radius:22rpx;background:#8b5cf6;color:#fff;font-size:30rpx;font-weight:900}
.btn.ghost{background:#f3f0ff;color:#6d28d9}
.btn.disabled{background:#c4b5fd;color:#fff}
