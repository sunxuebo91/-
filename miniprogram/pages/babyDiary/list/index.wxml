<view class="page">
  <view class="header">
    <view class="title">宝贝日记</view>
    <view class="subtitle" wx:if="{{mode === 'contracts'}}">
      <text wx:if="{{me.role === 'staff'}}">选择服务家庭，快速填写/查看今日记录</text>
      <text wx:else>选择服务合同，查看日记记录</text>
    </view>
    <view class="subtitle" wx:else>
      <text>{{contractTitle || '日记列表'}}</text>
    </view>
  </view>

  <view class="content">
    <!-- 合同列表模式 -->
    <view wx:if="{{mode === 'contracts'}}">
      <view wx:if="{{loading}}" class="skeleton">
        <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
      </view>

      <view wx:elif="{{contracts.length > 0}}" class="card-list">
        <view class="contract-card" wx:for="{{contracts}}" wx:key="_id" bindtap="onTapContract" data-id="{{item._id}}">
          <view class="card-top">
            <view class="card-title">
              <text class="emoji">🏠</text>
              <text class="text">{{item.babyInfo.name || '宝宝'}} · {{item.serviceDays}}天</text>

            </view>
            <view class="badge" wx:if="{{item.todayDiaryStatus}}" data-status="{{item.todayDiaryStatus}}">
              <text wx:if="{{item.todayDiaryStatus === 'published'}}">今日已发布</text>
              <text wx:elif="{{item.todayDiaryStatus === 'draft'}}">今日草稿</text>
              <text wx:else>今日已记录</text>
            </view>
          </view>

          <view class="card-meta">
            <view class="meta-item">服务：{{item.startDate}} ～ {{item.endDate}}</view>
            <view class="meta-item">进度：第 {{item.currentDay}}/{{item.serviceDays}} 天</view>
          </view>

          <view class="card-actions">
            <view class="btn ghost" wx:if="{{me.role !== 'staff'}}" catchtap="goDiaryList" data-id="{{item._id}}">查看日记</view>
            <view class="btn" wx:else catchtap="goToday" data-id="{{item._id}}">{{item.todayDiaryId ? '查看今日' : '立即填写'}}</view>
            <view class="arrow">›</view>
          </view>
        </view>
      </view>

      <view wx:else class="empty">
        <view class="empty-title">暂无可用合同</view>
        <view class="empty-desc" wx:if="{{me.role === 'staff'}}">请先为自己创建一条 active 合同（云函数限制只能创建自己为阿姨的合同）</view>
        <view class="empty-desc" wx:else>当前暂无可查看的服务合同</view>
        <view class="btn ghost" wx:if="{{me.role === 'staff'}}" bindtap="openCreateContract">创建测试合同</view>
      </view>
    </view>

    <!-- 日记列表模式（某合同） -->
    <view wx:else>
      <view wx:if="{{loading}}" class="skeleton">
        <view class="skeleton-row" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
      </view>

      <view wx:elif="{{diaries.length > 0}}" class="diary-list">
        <view class="diary-row" wx:for="{{diaries}}" wx:key="_id" bindtap="goDiaryDetail" data-id="{{item._id}}">
          <view class="row-left">
            <view class="row-title">{{item.serviceDate}} · 第 {{item.dayNumber || '-'}} 天</view>
            <view class="row-sub">状态：{{item.status === 'published' ? '已发布' : '草稿'}}</view>
          </view>
          <view class="row-right">
            <view class="pill" wx:if="{{item.status === 'published'}}">已发布</view>
            <view class="pill gray" wx:else>草稿</view>
            <view class="arrow">›</view>
          </view>
        </view>
      </view>

      <view wx:else class="empty">
        <view class="empty-title">暂无日记</view>
        <view class="empty-desc">该合同下还没有记录</view>
      </view>

      <view class="footer" wx:if="{{mode === 'diaries' && me.role === 'staff'}}">
        <view class="btn" bindtap="goCreateDiary">新建今日记录</view>
      </view>
    </view>
  </view>

  <!-- 创建测试合同弹窗 -->
  <view class="modal-mask" wx:if="{{showCreateContract}}" catchtap="closeCreateContract"></view>
  <view class="modal" wx:if="{{showCreateContract}}">
    <view class="modal-title">创建测试合同</view>
    <view class="modal-desc">仅用于快速跑通“宝贝日记”流程（需要你是 staff 且合同阿姨为本人）</view>

    <view class="form">
      <view class="field">
        <view class="label">客户 openid</view>
        <input class="input" placeholder="例如：oXXXX..." value="{{createContractForm.customerId}}" bindinput="onInputCreateContract" data-key="customerId" />
      </view>
      <view class="field">
        <view class="label">服务天数</view>
        <picker mode="selector" range="{{serviceDaysOptions}}" bindchange="onPickServiceDays">
          <view class="picker">{{createContractForm.serviceDays}} 天</view>
        </picker>
      </view>
      <view class="field">
        <view class="label">开始日期（YYYY-MM-DD）</view>
        <input class="input" placeholder="2026-01-28" value="{{createContractForm.startDate}}" bindinput="onInputCreateContract" data-key="startDate" />
      </view>
      <view class="field">
        <view class="label">宝宝小名</view>
        <input class="input" placeholder="小宝" value="{{createContractForm.babyName}}" bindinput="onInputCreateContract" data-key="babyName" />
      </view>
    </view>

    <view class="modal-actions">
      <view class="btn ghost" bindtap="closeCreateContract">取消</view>
      <view class="btn" bindtap="submitCreateContract">创建</view>
    </view>
  </view>
</view>
