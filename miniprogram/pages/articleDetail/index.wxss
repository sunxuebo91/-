/* 页面容器 */
.page {
  background: #fff;
  min-height: 100vh;
}

/* 顶部大图区域 */
.top-image-container {
  position: relative;
  width: 100%;
  background: #f5f5f5;
}

.top-swiper {
  width: 100%;
  /* 高度由 JS 动态计算，通过 style 属性设置 */
}

.top-image {
  width: 100%;
  height: 100%;
  object-fit: contain;  /* 完整显示图片，保持比例 */
}

/* 图片指示器（右下角） */
.image-indicator {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 内容容器 */
.content-container {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -24rpx;
  position: relative;
  z-index: 10;
  padding: 32rpx 32rpx 60rpx 32rpx;
}

/* 标题 */
.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #000;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

/* 作者信息栏 */
.author-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.author-info {
  flex: 1;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 6rpx;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
}

.view-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.view-icon {
  font-size: 28rpx;
}

.view-text {
  font-size: 26rpx;
  color: #666;
}

/* 正文内容区域 */
.article-content {
  color: #333;
  font-size: 30rpx;
  line-height: 1.8;
}

/* 摘要 */
.summary {
  padding: 24rpx 0;
  color: #666;
  font-size: 28rpx;
  line-height: 1.8;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

/* 正文 */
.content {
  color: #333;
  font-size: 30rpx;
  line-height: 1.8;
}

.content-empty {
  color: #999;
  font-size: 28rpx;
  text-align: center;
  padding: 80rpx 0;
}

/* 加载状态 */
.loading {
  color: #999;
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
}



