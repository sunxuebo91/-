/* 页面容器 */
.page {
  background: #fff;
  min-height: 100vh;
}

/* 顶部大图区域 */
.top-image-container {
  position: relative;
  width: 100%;
  background: #000;  /* 黑底，图片未加载时不会有色差条 */
  overflow: hidden;
}

.top-swiper {
  width: 100%;
  /* 高度由 JS 动态计算，通过 style 属性设置 */
}

.top-image {
  width: 100%;
  height: 100%;
  object-fit: cover;  /* 改为 cover 填满容器，避免上下留白 */
}

/* 图片指示器（右下角） */
.image-indicator {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 内容容器 */
.content-container {
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -28rpx;
  position: relative;
  z-index: 10;
  padding: 40rpx 36rpx 160rpx 36rpx;
}

/* 标题 */
.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #111;
  line-height: 1.45;
  margin-bottom: 20rpx;
  letter-spacing: 0.01em;
}

/* 作者信息栏 */
.author-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #ebebeb;
  margin-bottom: 24rpx;
}

.author-info {
  flex: 1;
}

.author-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.publish-time {
  font-size: 22rpx;
  color: #aaa;
}

.view-count {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.view-icon {
  font-size: 26rpx;
  opacity: 0.5;
}

.view-text {
  font-size: 24rpx;
  color: #aaa;
}

/* 正文内容区域 */
.article-content {
  color: #333;
  font-size: 30rpx;
  line-height: 1.9;
}

/* 摘要：引用块样式 */
.summary {
  padding: 20rpx 24rpx;
  background: #faf9ff;
  border-left: 6rpx solid #8766F3;
  border-radius: 0 12rpx 12rpx 0;
  color: #555;
  font-size: 27rpx;
  line-height: 1.85;
  margin-bottom: 32rpx;
  letter-spacing: 0.02em;
}

/* 正文 */
.content {
  color: #333;
  font-size: 30rpx;
  line-height: 1.9;
  word-break: break-all;
  letter-spacing: 0.02em;
}

.content-empty {
  color: #bbb;
  font-size: 28rpx;
  text-align: center;
  padding: 80rpx 0;
}

/* 加载状态 */
.loading {
  color: #bbb;
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
}

/* 分享进入的底部顾问信息 */
.bottom-contact {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.advisor-mini {
  display: flex;
  align-items: center;
  gap: 15rpx;
  flex: 1;
}
.advisor-mini-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  overflow: hidden;
  flex-shrink: 0;
}
.advisor-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
}
.advisor-mini-info {
  flex: 1;
  min-width: 0;
}
.advisor-mini-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.advisor-mini-company {
  font-size: 24rpx;
  color: #666;
}
.contact-btn {
  width: 220rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  border-radius: 40rpx;
  border: none;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(135, 102, 243, 0.3);
  line-height: normal;
  margin-left: 15rpx;
  flex-shrink: 0;
}
.contact-btn::after {
  border: none !important;
}