.page {
  padding: 20rpx;
  padding-bottom: 20rpx;
  background: #F7F5FF;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--ui-surface);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid var(--ui-border);
  box-shadow: var(--ui-shadow-card);
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 18rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.35;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #8a8a8a;
  font-size: 24rpx;
}

.meta-item {
  padding: 6rpx 12rpx;
  background: rgba(139, 92, 246, 0.08);
  border-radius: 999rpx;
}

.summary {
  margin-top: 18rpx;
  padding: 18rpx;
  background: #f7f7fb;
  border-radius: 16rpx;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.6;
}

.content {
  margin-top: 18rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.75;
}

.content-empty {
  margin-top: 18rpx;
  color: #9ca3af;
  font-size: 26rpx;
  text-align: center;
  padding: 40rpx 0;
}

.loading {
  color: #9ca3af;
  text-align: center;
  padding: 60rpx 0;
}



