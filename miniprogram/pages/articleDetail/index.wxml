<view class="page">
  <view class="card" wx:if="{{!loading}}">
    <image class="cover" wx:if="{{article.coverImage}}" src="{{article.coverImage}}" mode="aspectFill"></image>

    <view class="title">{{article.title || '文章详情'}}</view>

    <view class="meta">
      <text class="meta-item" wx:if="{{article.source}}">{{article.source}}</text>
      <text class="meta-item" wx:if="{{article.author}}">{{article.author}}</text>
      <text class="meta-item" wx:if="{{article.publishedAtText}}">{{article.publishedAtText}}</text>
      <text class="meta-item">{{viewCount}}阅读</text>
    </view>

    <view class="summary" wx:if="{{article.summary}}">{{article.summary}}</view>

    <view class="content" wx:if="{{contentNodes && contentNodes.length}}">
      <rich-text nodes="{{contentNodes}}"></rich-text>
    </view>

    <view class="content-empty" wx:if="{{!contentNodes || !contentNodes.length}}">暂无内容</view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>


</view>
