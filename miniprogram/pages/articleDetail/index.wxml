<view class="page">
  <!-- 小红书风格：顶部大图 -->
  <view class="top-image-container" wx:if="{{images && images.length > 0 && !loading}}">
    <swiper
      class="top-swiper"
      style="height: {{swiperHeight ? swiperHeight + 'px' : '100vw'}};"
      indicator-dots="{{false}}"
      autoplay="{{false}}"
      circular="{{true}}"
      bindchange="onSwiperChange"
    >
      <swiper-item wx:for="{{images}}" wx:key="index">
        <image
          class="top-image"
          src="{{item}}"
          mode="aspectFit"
          bindtap="previewImage"
          bindload="onImageLoad"
          data-index="{{index}}"
        ></image>
      </swiper-item>
    </swiper>

    <!-- 图片指示器（右下角） -->
    <view class="image-indicator" wx:if="{{images.length > 1}}">
      {{currentImageIndex + 1}}/{{images.length}}
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content-container" wx:if="{{!loading}}">
    <!-- 标题 -->
    <view class="title">{{article.title || '文章详情'}}</view>

    <!-- 作者信息栏 -->
    <view class="author-bar">
      <view class="author-info">
        <view class="author-name">{{article.author || '安得褓贝'}}</view>
        <view class="publish-time">{{article.publishedAtText || '刚刚'}}</view>
      </view>
      <view class="view-count">
        <text class="view-icon">👁</text>
        <text class="view-text">{{viewCount}}</text>
      </view>
    </view>

    <!-- 正文内容 -->
    <view class="article-content">
      <!-- 摘要 -->
      <view class="summary" wx:if="{{article.summary}}">{{article.summary}}</view>

      <!-- 正文 -->
      <view class="content" wx:if="{{contentNodes && contentNodes.length}}">
        <rich-text nodes="{{contentNodes}}"></rich-text>
      </view>

      <view class="content-empty" wx:if="{{!contentNodes || !contentNodes.length}}">暂无内容</view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>
