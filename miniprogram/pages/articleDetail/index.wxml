<view class="page">
  <!-- 小红书风格：顶部大图 -->
  <view class="top-image-container" wx:if="{{images && images.length > 0 && !loading}}">
    <swiper
      class="top-swiper"
      style="height: {{swiperHeight + 'px'}};"
      indicator-dots="{{false}}"
      autoplay="{{false}}"
      circular="{{true}}"
      bindchange="onSwiperChange"
    >
      <swiper-item wx:for="{{images}}" wx:key="index">
        <image
          class="top-image"
          src="{{item}}"
          mode="aspectFill"
          bindtap="previewImage"
          bindload="onImageLoad"
          data-index="{{index}}"
        ></image>
      </swiper-item>
    </swiper>

    <!-- 图片指示器（右下角） -->
    <view class="image-indicator" wx:if="{{images.length > 1}}">
      {{currentImageIndex + 1}}/{{images.length}}
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content-container {{images && images.length > 0 ? '' : 'content-container--no-image'}}" wx:if="{{!loading}}">
    <view class="article-kicker">{{article.source || '育儿分享'}}</view>

    <!-- 标题 -->
    <view class="title">{{article.title || '文章详情'}}</view>

    <!-- 作者信息栏 -->
    <view class="author-bar">
      <view class="author-info">
        <view class="author-name">{{article.author || '安得褓贝'}}</view>
        <view class="publish-time">{{article.publishedAtText || '刚刚'}}</view>
      </view>
      <view class="view-count">
        <text class="view-label">阅读</text>
        <text class="view-text">{{viewCount}}</text>
      </view>
    </view>

    <!-- 正文内容 -->
    <view class="article-content">
      <!-- 摘要 -->
      <view class="summary-card" wx:if="{{article.summary}}">
        <view class="summary-label">导读</view>
        <view class="summary">{{article.summary}}</view>
      </view>

      <!-- 正文 -->
      <view class="content" wx:if="{{contentHtml}}">
        <rich-text nodes="{{contentHtml}}" space="nbsp"></rich-text>
      </view>

      <view class="content-empty" wx:if="{{!contentHtml}}">暂无内容</view>
    </view>

    <view class="article-disclaimer">内容仅供参考，不作为诊断、治疗或用药依据，具体请遵医嘱或及时就医。</view>
  </view>

  <view class="share-mask" wx:if="{{showSharePanel}}" catchtap="closeSharePanel"></view>

  <view class="share-fab-wrap {{isShared && sharerInfo ? 'share-fab-wrap--with-contact' : ''}}" wx:if="{{!loading && article._id}}">
    <view class="share-action-list" wx:if="{{showSharePanel}}">
      <button class="share-action-btn share-action-btn--friend" open-type="share" bindtap="onBeforeShare">转发给好友</button>
      <button class="share-action-btn share-action-btn--timeline" bindtap="shareToMoments">分享到朋友圈</button>
    </view>

    <view class="share-fab-main" catchtap="toggleSharePanel">
      <text class="share-fab-icon">{{showSharePanel ? '×' : '↗'}}</text>
      <text class="share-fab-text">{{showSharePanel ? '收起' : '转发'}}</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <!-- 分享进入：顾问信息 + 联系按钮 -->
  <view wx:if="{{isShared && sharerInfo}}" class="bottom-contact">
    <view class="advisor-mini">
      <view class="advisor-mini-avatar">
        <image wx:if="{{sharerInfo.avatar}}" src="{{sharerInfo.avatar}}" mode="aspectFill" class="advisor-avatar-img" />
        <text wx:else>{{sharerInfo.name ? sharerInfo.name.charAt(0) : '顾'}}</text>
      </view>
      <view class="advisor-mini-info">
        <view class="advisor-mini-name">{{sharerInfo.name || '安得褓贝顾问'}}</view>
        <view class="advisor-mini-company">{{sharerInfo.company || '安得褓贝'}}</view>
      </view>
    </view>
    <button class="contact-btn" bindtap="onContactAdvisor">联系顾问</button>
  </view>
</view>
