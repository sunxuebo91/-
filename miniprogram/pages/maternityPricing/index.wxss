page {
  background: #FFF5F8;
  min-height: 100vh;
}

.pricing-page {
  min-height: 100vh;
  padding-bottom: 220rpx;
  background: #FFF5F8;
}

/* 顶部装饰背景 */
.header-bg {
  position: relative;
  /* 距离顶部导航栏 20px，距离下方内容 20px（与育儿报价一致） */
  padding: 20px 0;
  background: linear-gradient(180deg, #FFB6D9 0%, #FFF5F8 100%);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 装饰元素 */
.decoration-leaf {
  position: absolute;
  font-size: 48rpx;
  opacity: 0.3;
  animation: float 3s ease-in-out infinite;
}

.decoration-leaf-1 {
  top: 20rpx;
  left: 40rpx;
  animation-delay: 0s;
}

.decoration-leaf-2 {
  top: 100rpx;
  right: 60rpx;
  animation-delay: 1s;
}

.decoration-leaf-3 {
  bottom: 40rpx;
  left: 60rpx;
  animation-delay: 2s;
}

.decoration-star {
  position: absolute;
  font-size: 32rpx;
  opacity: 0.4;
  animation: twinkle 2s ease-in-out infinite;
}

.decoration-star-1 {
  top: 60rpx;
  right: 120rpx;
  animation-delay: 0.5s;
}

.decoration-star-2 {
  bottom: 80rpx;
  right: 40rpx;
  animation-delay: 1.5s;
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

@keyframes twinkle {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.2); }
}

/* 标题区域 */
.title-section {
  margin: 0;
  padding: 0 32rpx;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.title-badge {
  background: linear-gradient(135deg, #FF4081 0%, #FFB6D9 100%);
  padding: 20rpx 60rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 64, 129, 0.28);
}

.title-icon {
  font-size: 36rpx;
  margin: 0 12rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.18);
}

.main-title {
  font-size: 56rpx;
  font-weight: 900;
  color: #FF1744;
  text-shadow: 2rpx 2rpx 8rpx rgba(255, 23, 68, 0.3);
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF4081;
  letter-spacing: 2rpx;
}

/* 等级说明 */
.level-description {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  padding: 0 32rpx;
  z-index: 2;
  position: relative;
}

.desc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.desc-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.desc-content .highlight {
  color: #FF4081;
  font-weight: 600;
}

/* 说明文字 */
.description {
  text-align: center;
  padding: 0 48rpx;
  z-index: 1;
}

.desc-line {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 4rpx;
}

.desc-line.highlight {
  color: #FF1744;
  font-weight: 600;
}

/* 等级卡片容器 */
.levels-container {
  /* 顶部间距统一由 .header-bg 的 padding-bottom(20px) 控制，确保上下均为 20px */
  padding: 0 24rpx 32rpx;
}

.level-card {
  margin-bottom: 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.level-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.level-badge {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.level-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2rpx;
}

.price-tag {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-icon {
  font-size: 40rpx;
}

.price-wrapper {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.price-suffix {
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
}

.price-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: #999;
}

/* 经验标签 */
.experience-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.experience-icon {
  margin-right: 8rpx;
}

/* 技能网格 */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 8rpx;
}

.skill-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  transition: transform 0.2s ease;
}

.skill-item:active {
  transform: scale(0.95);
}

.skill-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.skill-name {
  font-size: 22rpx;
  color: #333;
  text-align: center;
  font-weight: 600;
  line-height: 1.3;
}

/* 额外服务区域 */
.extra-section {
  margin: 32rpx 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB3 100%);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 157, 0.3);
}

.extra-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.extra-note {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 32rpx;
  font-style: italic;
}

.extra-services {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.extra-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.extra-item:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.25);
}

.extra-icon-box {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  line-height: 48rpx;
}

.extra-icon-image {
  width: 40rpx;
  height: 40rpx;
}

.extra-name {
  font-size: 22rpx;
  color: #fff;
  text-align: center;
  line-height: 1.4;
  word-break: break-all;
}

/* 专业能力定向匹配 */
.special-ability-section {
  margin: 32rpx 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(78, 205, 196, 0.3);
}

.special-ability-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.special-ability-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.special-ability-subtitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.special-ability-note {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-style: italic;
  line-height: 1.6;
}

.special-ability-cards {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.special-ability-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.special-ability-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.special-ability-icon-box {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #E0F7F6 0%, #B2EBF2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.2);
}

.special-ability-icon {
  font-size: 56rpx;
}

.special-ability-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.special-ability-desc {
  font-size: 22rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
}

/* 底部说明 */
.bottom-info {
  margin: 32rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.info-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.info-text {
  flex: 1;
}

.info-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.info-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部留白 */
.bottom-space {
  height: 220rpx;
}

/* 底部悬浮分享按钮 */
.share-fab {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 24rpx;
  z-index: 50;

  /* 兼容底部安全区 */
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.share-fab-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB3 100%);
  box-shadow: 0 16rpx 36rpx rgba(255, 107, 157, 0.38);

  line-height: 1;
}

.share-fab-btn::after {
  border: none;
}

.share-fab-btn-hover {
  opacity: 0.92;
}

.share-fab-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.share-fab-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

