.page {
  min-height: 100vh;
  background: #f6f6f6;
}

.scroll {
  height: 100vh;
}

.card {
  margin: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.h2 {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin: 24rpx 0 12rpx;
}

.p {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 12rpx;
}
