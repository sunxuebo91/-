<view class="page {{isShared && sharerInfo && sharerIsStaff ? 'has-bottom-bar' : ''}}">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loader"></view>
    <view class="state-text">加载中</view>
  </view>

  <block wx:elif="{{course}}">
    <!-- 吸顶播放区 -->
    <view class="player-sticky">
      <view class="video-wrap" style="height: {{videoWrapHeight}}rpx;">
        <video
          wx:if="{{playingLessonId}}"
          id="coursePlayer"
          class="video"
          src="{{playUrl}}"
          poster="{{course.cover}}"
          initial-time="{{lastPosition}}"
          object-fit="contain"
          enable-progress-gesture
          show-fullscreen-btn
          playsinline
          autoplay
          show-play-btn
          show-center-play-btn="{{false}}"
          auto-pause-if-navigate
          auto-pause-if-open-native
          bindloadedmetadata="onLoadedMetadata"
          bindtimeupdate="onTimeUpdate"
          bindended="onEnded"
          bindplay="onPlay"
          bindwaiting="onWaiting"
          binderror="onError"
        ></video>
        <view wx:else class="video-placeholder">
          <image class="video-placeholder-img" src="{{course.cover || '/images/default-goods-image.png'}}" mode="aspectFill"/>
          <view class="video-placeholder-mask"></view>
        </view>
        <view wx:if="{{buffering}}" class="buffering">
          <view class="buffering-dot"></view>
          <view class="buffering-dot"></view>
          <view class="buffering-dot"></view>
        </view>
      </view>
      <view class="now-bar" wx:if="{{playingLesson}}">
        <view class="now-meta">
          <text class="now-tag">正在学习</text>
          <text class="now-index" wx:if="{{playingIndex >= 0}}">{{playingLesson.indexLabel}} / {{lessons.length < 10 ? '0' : ''}}{{lessons.length}}</text>
        </view>
        <view class="now-title">{{playingLesson.title}}</view>
        <view class="now-course">{{course.title}}</view>
      </view>
    </view>

    <!-- 课程目录 -->
    <view class="section-head">
      <view class="section-title">课程目录</view>
      <view class="section-count">{{lessons.length}} 节</view>
    </view>

    <view class="chapter-list">
      <block wx:for="{{groups}}" wx:for-item="group" wx:key="id">
        <!-- 章分组标题：仅"分章模式"（任一章 title 非空）下显示 -->
        <view wx:if="{{showGroupHead}}" class="group-head">
          <text class="group-title">{{group.title}}</text>
          <text class="group-count">{{group.lessons.length}} 节</text>
        </view>
        <view class="chapter-card {{lesson.id === playingLessonId ? 'is-playing' : ''}} {{lesson.completed ? 'is-done' : ''}}"
              wx:for="{{group.lessons}}" wx:for-item="lesson" wx:key="id"
              bindtap="playLesson" data-id="{{lesson.id}}"
              hover-class="chapter-card-hover" hover-stay-time="60">
          <view class="chapter-leading">
            <block wx:if="{{lesson.id === playingLessonId}}">
              <view class="eq"><view></view><view></view><view></view></view>
            </block>
            <block wx:elif="{{lesson.completed}}">
              <view class="leading-check">✓</view>
            </block>
            <block wx:else>
              <text class="leading-index">{{lesson.indexLabel}}</text>
            </block>
          </view>

          <view class="chapter-body">
            <view class="chapter-title">{{lesson.title}}</view>
            <view class="chapter-meta">
              <text class="meta-duration" wx:if="{{lesson.durationText}}">{{lesson.durationText}}</text>
              <text class="meta-dot" wx:if="{{lesson.durationText && lesson.progressText}}">·</text>
              <text class="meta-progress {{lesson.completed ? 'is-done' : ''}}" wx:if="{{lesson.progressText}}">{{lesson.progressText}}</text>
            </view>
            <view class="chapter-bar" wx:if="{{!lesson.completed && lesson.progressPercent > 0 && lesson.id !== playingLessonId}}">
              <view class="chapter-bar-fill" style="width: {{lesson.progressPercent}}%"></view>
            </view>
          </view>

          <view class="chapter-trailing">
            <text wx:if="{{lesson.id === playingLessonId}}" class="pill-now">播放中</text>
            <text wx:else class="arrow">›</text>
          </view>
        </view>
      </block>
    </view>

    <view class="list-footer">— 已经到底了 —</view>

    <!-- 员工专属：课程宣传海报悬浮按钮（左下角）；员工扫他人分享码时不显示，避免与底部顾问条重叠 -->
    <view
      wx:if="{{isStaff && !isShared}}"
      class="promo-fab {{generatingPromo ? 'promo-fab--loading' : ''}}"
      style="background: linear-gradient(135deg, {{themeColor}} 0%, {{themeColorDark}} 100%);"
      bindtap="onTapPromoCourse"
      hover-class="promo-fab--hover"
      hover-stay-time="80"
    >
      <text class="promo-fab__icon">📣</text>
      <text class="promo-fab__text">课程宣传</text>
    </view>

    <!-- 分享进入的客户：底部固定顾问联系条（仅员工分享的链接才显示） -->
    <view wx:if="{{isShared && sharerInfo && sharerIsStaff}}" class="bottom-bar">
      <view class="bottom-contact">
        <view class="advisor-mini">
          <view class="advisor-mini-avatar">
            <image wx:if="{{sharerInfo.avatar}}" src="{{sharerInfo.avatar}}" mode="aspectFill" class="advisor-avatar-img" />
            <text wx:else>{{sharerInfo.name ? sharerInfo.name.charAt(0) : '顾'}}</text>
          </view>
          <view class="advisor-mini-info">
            <view class="advisor-mini-name">{{sharerInfo.name || '安得褓贝顾问'}}</view>
            <view class="advisor-mini-company">{{sharerInfo.company || '安得褓贝'}}</view>
          </view>
        </view>
        <button class="contact-btn" bindtap="onContactAdvisor">联系顾问</button>
      </view>
    </view>
  </block>
</view>

<!-- 海报生成用：屏外定位的两块 canvas（封面主色采样 + 海报合成） -->
<canvas type="2d" id="colorSampler" style="position:fixed;left:-9999px;top:0;width:32px;height:32px;"></canvas>
<canvas type="2d" id="coursePosterCanvas" style="position:fixed;left:-9999px;top:0;width:375px;height:1000px;"></canvas>
