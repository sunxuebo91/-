<view class="page">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loader"></view>
    <view class="state-text">加载中</view>
  </view>

  <block wx:elif="{{course}}">
    <!-- 吸顶播放区 -->
    <view class="player-sticky">
      <view class="video-wrap" style="height: {{videoWrapHeight}}rpx;">
        <video
          wx:if="{{playingChapterId}}"
          id="coursePlayer"
          class="video"
          src="{{playUrl}}"
          poster="{{course.cover}}"
          initial-time="{{lastPosition}}"
          object-fit="contain"
          enable-progress-gesture
          show-fullscreen-btn
          playsinline
          autoplay
          show-play-btn
          show-center-play-btn="{{false}}"
          auto-pause-if-navigate
          auto-pause-if-open-native
          bindloadedmetadata="onLoadedMetadata"
          bindtimeupdate="onTimeUpdate"
          bindended="onEnded"
          bindplay="onPlay"
          bindwaiting="onWaiting"
          binderror="onError"
        ></video>
        <view wx:else class="video-placeholder">
          <image class="video-placeholder-img" src="{{course.cover || '/images/default-goods-image.png'}}" mode="aspectFill"/>
          <view class="video-placeholder-mask"></view>
        </view>
        <view wx:if="{{buffering}}" class="buffering">
          <view class="buffering-dot"></view>
          <view class="buffering-dot"></view>
          <view class="buffering-dot"></view>
        </view>
      </view>
      <view class="now-bar" wx:if="{{playingChapter}}">
        <view class="now-meta">
          <text class="now-tag">正在学习</text>
          <text class="now-index" wx:if="{{playingIndex >= 0}}">{{playingChapter.indexLabel}} / {{chapters.length < 10 ? '0' : ''}}{{chapters.length}}</text>
        </view>
        <view class="now-title">{{playingChapter.title}}</view>
        <view class="now-course">{{course.title}}</view>
      </view>
    </view>

    <!-- 章节目录 -->
    <view class="section-head">
      <view class="section-title">课程目录</view>
      <view class="section-count">{{chapters.length}} 节</view>
    </view>

    <view class="chapter-list">
      <view class="chapter-card {{item.id === playingChapterId ? 'is-playing' : ''}} {{item.completed ? 'is-done' : ''}}"
            wx:for="{{chapters}}" wx:key="id"
            bindtap="playChapter" data-id="{{item.id}}"
            hover-class="chapter-card-hover" hover-stay-time="60">
        <view class="chapter-leading">
          <block wx:if="{{item.id === playingChapterId}}">
            <view class="eq"><view></view><view></view><view></view></view>
          </block>
          <block wx:elif="{{item.completed}}">
            <view class="leading-check">✓</view>
          </block>
          <block wx:else>
            <text class="leading-index">{{item.indexLabel}}</text>
          </block>
        </view>

        <view class="chapter-body">
          <view class="chapter-title">{{item.title}}</view>
          <view class="chapter-meta">
            <text class="meta-duration" wx:if="{{item.durationText}}">{{item.durationText}}</text>
            <text class="meta-dot" wx:if="{{item.durationText && item.progressText}}">·</text>
            <text class="meta-progress {{item.completed ? 'is-done' : ''}}" wx:if="{{item.progressText}}">{{item.progressText}}</text>
          </view>
          <view class="chapter-bar" wx:if="{{!item.completed && item.progressPercent > 0 && item.id !== playingChapterId}}">
            <view class="chapter-bar-fill" style="width: {{item.progressPercent}}%"></view>
          </view>
        </view>

        <view class="chapter-trailing">
          <text wx:if="{{item.id === playingChapterId}}" class="pill-now">播放中</text>
          <text wx:else class="arrow">›</text>
        </view>
      </view>
    </view>

    <view class="list-footer">— 已经到底了 —</view>
  </block>
</view>
