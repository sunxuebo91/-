page {
  background: #F4F4F7;
}
.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}
/* 分享进入：底部固定顾问条占位，避免 list-footer 被遮挡 */
.page.has-bottom-bar {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom, 0));
}

/* ==== 加载态 ==== */
.state-wrap {
  padding: 200rpx 0;
  text-align: center;
}
.state-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #999;
  letter-spacing: 2rpx;
}
.loader {
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto;
  border: 4rpx solid #E5E3EC;
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ==== 吸顶播放区 ==== */
.player-sticky {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #0E0E12;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.18);
}
.video-wrap {
  position: relative;
  width: 100%;
  height: 422rpx; /* 首屏兜底 16:9；实际高度由 JS 根据视频元数据动态写入 inline style */
  background: #000;
  transition: height 0.2s ease;
}
.video {
  width: 100%;
  height: 100%;
  display: block;
}
.video-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
  background: #000;
  overflow: hidden;
}
.video-placeholder-img {
  width: 100%;
  height: 100%;
  filter: blur(20rpx);
  opacity: 0.45;
  transform: scale(1.1);
}
.video-placeholder-mask {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.7) 100%);
}

/* 缓冲三点动画 */
.buffering {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(10rpx);
  border-radius: 40rpx;
}
.buffering-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fff;
  animation: dot-bounce 1.2s infinite ease-in-out;
}
.buffering-dot:nth-child(2) { animation-delay: 0.15s; }
.buffering-dot:nth-child(3) { animation-delay: 0.3s; }
@keyframes dot-bounce {
  0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
  40% { opacity: 1; transform: translateY(-6rpx); }
}

/* 当前章节信息条 */
.now-bar {
  padding: 28rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #0E0E12 0%, #16161D 100%);
  color: #fff;
}
.now-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.now-tag {
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #8b5cf6 0%, #6d49e8 100%);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  letter-spacing: 2rpx;
}
.now-index {
  font-size: 22rpx;
  color: #8E8E99;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  letter-spacing: 1rpx;
}
.now-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  color: #FFFFFF;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.now-course {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6E6E78;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==== 章节目录头 ==== */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 40rpx 32rpx 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A22;
  letter-spacing: 1rpx;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 26rpx;
  background: linear-gradient(180deg, #8b5cf6, #6d49e8);
  border-radius: 4rpx;
  margin-right: 14rpx;
  vertical-align: -3rpx;
}
.section-count {
  font-size: 24rpx;
  color: #9A9AA5;
}

/* ==== 章节卡片列表 ==== */
.chapter-list {
  padding: 0 24rpx;
}

/* 章分组标题（多章课程使用；单章课程在 WXML 层隐藏） */
.group-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 22rpx 12rpx 12rpx;
  margin-top: 8rpx;
}
.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #6E6E78;
  letter-spacing: 1rpx;
}
.group-count {
  font-size: 22rpx;
  color: #B0B0BB;
}
.chapter-card {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(20, 20, 40, 0.03);
  position: relative;
  transition: transform 0.15s ease;
}
.chapter-card-hover {
  transform: scale(0.985);
  background: #FAFAFE;
}
.chapter-card.is-playing {
  background: linear-gradient(135deg, #F5F1FF 0%, #FFFFFF 100%);
  box-shadow: 0 6rpx 20rpx rgba(139, 92, 246, 0.12);
}
.chapter-card.is-playing::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  background: linear-gradient(180deg, #8b5cf6, #6d49e8);
  border-radius: 0 4rpx 4rpx 0;
}

/* 左侧编号 / 状态 */
.chapter-leading {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.leading-index {
  font-size: 32rpx;
  font-weight: 500;
  color: #C8C8D0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  letter-spacing: 2rpx;
}
.leading-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #22D3A5, #10B981);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  line-height: 48rpx;
  box-shadow: 0 4rpx 10rpx rgba(16, 185, 129, 0.25);
}

/* 等分线动效（正在播放） */
.eq {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 32rpx;
}
.eq view {
  width: 6rpx;
  background: linear-gradient(180deg, #a78bfa, #6d49e8);
  border-radius: 3rpx;
  animation: eq-bounce 1s ease-in-out infinite;
}
.eq view:nth-child(1) { height: 60%; animation-delay: -0.2s; }
.eq view:nth-child(2) { height: 100%; animation-delay: -0.4s; }
.eq view:nth-child(3) { height: 75%; animation-delay: -0.6s; }
@keyframes eq-bounce {
  0%, 100% { transform: scaleY(0.4); }
  50%      { transform: scaleY(1); }
}

/* 中间内容 */
.chapter-body {
  flex: 1;
  margin: 0 20rpx;
  min-width: 0;
}
.chapter-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A22;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.is-playing .chapter-title { color: #6d49e8; font-weight: 600; }
.is-done .chapter-title { color: #6A6A75; }

.chapter-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9A9AA5;
}
.meta-duration {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  letter-spacing: 0.5rpx;
}
.meta-dot { color: #D8D8DF; }
.meta-progress { color: #8b5cf6; }
.meta-progress.is-done { color: #10B981; }

/* 卡片内进度条 */
.chapter-bar {
  margin-top: 16rpx;
  height: 4rpx;
  background: #EDEAF5;
  border-radius: 2rpx;
  overflow: hidden;
}
.chapter-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #a78bfa, #6d49e8);
  border-radius: 2rpx;
}

/* 右侧 */
.chapter-trailing {
  flex-shrink: 0;
  min-width: 80rpx;
  text-align: right;
}
.pill-now {
  display: inline-block;
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #8b5cf6 0%, #6d49e8 100%);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 10rpx rgba(139, 92, 246, 0.3);
}
.arrow {
  font-size: 40rpx;
  color: #D8D8DF;
  font-weight: 300;
  line-height: 1;
}

.list-footer {
  text-align: center;
  font-size: 22rpx;
  color: #C0C0CA;
  padding: 40rpx 0 20rpx;
  letter-spacing: 4rpx;
}

/* ==== 员工专属：课程宣传悬浮按钮（右下角，避开手势栏） ==== */
.promo-fab {
  position: fixed;
  right: 28rpx;
  /* iOS 底部手势栏一般 34pt(≈ 110-130rpx)，再多留一点呼吸空间 */
  bottom: calc(140rpx + env(safe-area-inset-bottom, 0));
  z-index: 99;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 28rpx;
  border-radius: 50rpx;
  color: #FFFFFF;
  /* background 颜色由 inline style 注入（来自封面主色） */
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.22);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  animation: promo-fab-in 0.32s ease both;
}
.promo-fab--hover {
  transform: scale(0.95);
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.18);
}
.promo-fab--loading {
  opacity: 0.7;
  pointer-events: none;
}
.promo-fab__icon {
  font-size: 28rpx;
  line-height: 1;
}
.promo-fab__text {
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
@keyframes promo-fab-in {
  from { opacity: 0; transform: translateY(20rpx) scale(0.85); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* ==== 分享进入：底部固定顾问联系条（复用 resumeDetail 视觉） ==== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(247, 245, 255, 0.98);
  backdrop-filter: blur(20px);
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}
.bottom-contact {
  display: flex;
  align-items: center;
  width: 100%;
}
.advisor-mini {
  display: flex;
  align-items: center;
  gap: 15rpx;
  flex: 1;
}
.advisor-mini-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  overflow: hidden;
}
.advisor-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
}
.advisor-mini-info {
  flex: 1;
}
.advisor-mini-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}
.advisor-mini-company {
  font-size: 24rpx;
  color: #666;
}
.contact-btn {
  flex: 1;
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  border-radius: 36rpx;
  border: none;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(135, 102, 243, 0.3);
  line-height: normal;
}
.contact-btn::after {
  border: none !important;
}
.contact-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}
