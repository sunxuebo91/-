.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 48rpx;
}

.content {
  width: 100%;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 64rpx;
  text-align: center;
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.register-btn {
  width: 100%;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(135, 102, 243, 0.3);
}

.register-btn::after {
  border: none;
}

.btn-text {
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-tip {
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.tip-text {
  color: #999;
}

.login-link {
  color: #8766F3;
  font-weight: 600;
  margin-left: 8rpx;
}

