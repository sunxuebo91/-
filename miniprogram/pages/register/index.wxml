<view class="page">
  <view class="content">
    <view class="title">注册账号</view>
    <view class="subtitle">创建您的账号</view>

    <view class="form">
      <view class="form-item">
        <view class="label">账号</view>
        <input class="form-input" type="text" placeholder="请输入账号（字母或数字）" value="{{username}}" bindinput="onUsernameInput" />
      </view>

      <view class="form-item">
        <view class="label">密码</view>
        <input class="form-input" type="password" placeholder="请输入密码（至少6位）" value="{{password}}" bindinput="onPasswordInput" />
      </view>

      <view class="form-item">
        <view class="label">确认密码</view>
        <input class="form-input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>

      <view class="form-item">
        <view class="label">昵称</view>
        <input class="form-input" type="nickname" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
      </view>
    </view>

    <button class="register-btn" bindtap="onRegister">
      <view class="btn-text">立即注册</view>
    </button>

    <view class="login-tip">
      <text class="tip-text">已有账号？</text>
      <text class="login-link" bindtap="goLogin">立即登录</text>
    </view>
  </view>
</view>

