page {
  background: #f2f6f5;
  min-height: 100vh;
}

.page {
  padding: 24rpx 24rpx 80rpx;
}

/* ① 服务费 Hero 卡片 */
.fee-hero {
  background: linear-gradient(135deg, #20B2A0 0%, #48D1C4 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(32, 178, 160, 0.35);
}

.fee-hero-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  text-align: center;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}

.fee-formula {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.formula-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
}

.formula-result {
  background: rgba(255,255,255,0.32);
}

.formula-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
}

.result-num { font-size: 36rpx; }

.formula-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

.formula-eq {
  font-size: 48rpx;
  font-weight: 300;
  color: rgba(255,255,255,0.7);
}

.fee-example {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(0,0,0,0.1);
  border-radius: 40rpx;
  padding: 12rpx 28rpx;
}

/* ② 签约优惠卡片 */
.promo-card {
  position: relative;
  background: linear-gradient(135deg, #fff8e1 0%, #fff3cd 100%);
  border: 2rpx solid #FFB800;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 0, 0.2);
}

.promo-badge {
  position: absolute;
  top: -2rpx;
  right: 28rpx;
  background: linear-gradient(135deg, #FFB800, #FF9500);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.promo-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.promo-icon { font-size: 56rpx; }

.promo-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #b8860b;
  margin-bottom: 8rpx;
}

.promo-note {
  font-size: 20rpx;
  font-weight: 400;
  color: #8a6800;
  margin-left: 8rpx;
}

.promo-desc {
  font-size: 24rpx;
  color: #8a6800;
  line-height: 1.6;
}

/* ③ 服务特色 */
.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #20B2A0);
}

.section-line:last-child {
  background: linear-gradient(90deg, #20B2A0, transparent);
}

.section-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #20B2A0;
  white-space: nowrap;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.feature-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  border-top: 4rpx solid #20B2A0;
}

.feature-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.feature-icon {
  font-size: 30rpx;
  line-height: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.2;
}

.feature-desc {
  font-size: 22rpx;
  color: #888;
  line-height: 1.6;
}

/* ④ 底部说明 */
.bottom-note {
  padding: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.note-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.note-item {
  font-size: 24rpx;
  color: #888;
  line-height: 2;
}

.contact-btn {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #20B2A0 0%, #48D1C4 100%);
  box-shadow: 0 6rpx 20rpx rgba(32, 178, 160, 0.35);
  border: none;
}

.contact-btn::after { border: none; }

.contact-icon { font-size: 30rpx; }

.contact-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}
