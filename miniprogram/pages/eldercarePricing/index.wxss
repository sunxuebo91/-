page {
  background: #FFFBF0;
  min-height: 100vh;
}

.pricing-page {
  min-height: 100vh;
  padding-bottom: 220rpx;
  background: #FFFBF0;
}

/* 顶部装饰背景 */
.header-bg {
  position: relative;
  /* 距离顶部导航栏 20px，距离下方白色卡片 20px */
  padding: 20px 0;
  background: linear-gradient(180deg, #FFB800 0%, #FFFBF0 100%);
  overflow: hidden;

  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 装饰元素 */
.decoration-leaf {
  position: absolute;
  font-size: 48rpx;
  opacity: 0.3;
  animation: float 3s ease-in-out infinite;
}

.decoration-leaf-1 {
  top: 40rpx;
  left: 60rpx;
  animation-delay: 0s;
}

.decoration-leaf-2 {
  top: 80rpx;
  right: 80rpx;
  animation-delay: 1s;
}

.decoration-leaf-3 {
  top: 120rpx;
  left: 50%;
  animation-delay: 2s;
}

.decoration-star {
  position: absolute;
  font-size: 32rpx;
  opacity: 0.4;
  animation: twinkle 2s ease-in-out infinite;
}

.decoration-star-1 {
  top: 60rpx;
  right: 40rpx;
  animation-delay: 0.5s;
}

.decoration-star-2 {
  bottom: 30rpx;
  right: 50%;
  animation-delay: 1.5s;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

@keyframes twinkle {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* 标题区域 */
.title-section {
  position: relative;
  z-index: 1;
}

.title-badge {
  background: linear-gradient(135deg, #FFB800 0%, #FFA500 100%);
  padding: 20rpx 60rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.3);
}

.title-icon {
  font-size: 36rpx;
  margin: 0 12rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 说明文字 */
.description {
  /* 与星级按钮的间距由 .header-bg 的 padding-bottom(20px) 控制 */
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 0, 0.1);
  backdrop-filter: blur(10rpx);
}

.desc-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.highlight {
  color: #FFB800;
  font-weight: 600;
}

/* 等级卡片容器 */
.levels-container {
  padding: 0 32rpx;
}

.level-card {
  margin-bottom: 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 0, 0.15);
  transition: transform 0.2s ease;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.level-card:active {
  transform: scale(0.98);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.level-badge {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.level-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.price-tag {
  display: flex;
  align-items: baseline;
}

.price {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 经验标签 */
.experience-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.experience-icon {
  margin-right: 8rpx;
}

/* 技能网格 */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 8rpx;
}

.skill-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  transition: transform 0.2s ease;
}

.skill-item:active {
  transform: scale(0.95);
}

.skill-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.skill-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  line-height: 1.4;
}

/* 额外服务区域 */
.extra-section {
  margin: 40rpx 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #FFB800 0%, #FFA500 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 0, 0.3);
}

.extra-title {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.extra-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.extra-subtitle {
  text-align: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.extra-note {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 24rpx;
  font-style: italic;
}

.extra-services {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.extra-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.extra-item:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.25);
}

.extra-icon-box {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  line-height: 48rpx;
}

.extra-name {
  font-size: 22rpx;
  color: #fff;
  text-align: center;
  line-height: 1.3;
  font-weight: 600;
}

.extra-desc {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  margin-top: 4rpx;
  line-height: 1.2;
}

/* 底部留白 */
.bottom-space {
  height: 140rpx;
}

/* 底部悬浮分享按钮 */
.share-fab {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 24rpx;
  z-index: 50;

  /* 兼容底部安全区 */
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.share-fab-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 999rpx;

  background: linear-gradient(135deg, #FFB800 0%, #FFA500 100%);
  box-shadow: 0 16rpx 36rpx rgba(255, 184, 0, 0.38);

  line-height: 1;
}

.share-fab-btn::after {
  border: none;
}

.share-fab-btn-hover {
  opacity: 0.92;
}

.share-fab-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.share-fab-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}


