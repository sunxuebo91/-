.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 24rpx;
  box-sizing: border-box;
}

/* Tab 切换器 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}
.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0 24rpx;
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  transition: color 0.2s;
}
.tab-item.active {
  color: #8766F3;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  background: #8766F3;
  border-radius: 3rpx;
}
.tab-dot {
  align-self: flex-start;
  margin: 6rpx 0 0 6rpx;
  width: 14rpx;
  height: 14rpx;
  background: #ff4d4f;
  border-radius: 50%;
}

/* 状态页（加载中/空） */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 160rpx;
}
.state-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.state-text { font-size: 32rpx; color: #555; font-weight: 500; }
.state-sub { font-size: 26rpx; color: #999; margin-top: 12rpx; }

/* 历史记录分隔线 */
.history-divider {
  display: flex; align-items: center;
  margin: 8rpx 20rpx 20rpx;
}
.history-divider::before,
.history-divider::after {
  content: ''; flex: 1;
  height: 1rpx; background: #e0e0e0;
}
.history-divider-text {
  font-size: 22rpx; color: #bbb;
  padding: 0 20rpx; white-space: nowrap;
}

/* 卡片 */
.contract-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 0 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.service-type {
  font-size: 34rpx;
  font-weight: 600;
  color: #8766F3;
}

/* 历史合同卡片：灰化 */
.card-history { opacity: 0.6; }

/* 状态徽章 */
.status-badge {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}
.status-signing   { background: #f0ecfd; color: #8766F3; }
.status-signed    { background: #ece6fd; color: #6b4fc7; }
.status-active    { background: #8766F3; color: #fff; }
.status-ended     { background: #f0f0f0; color: #999; }
.status-cancelled { background: #f5e8f0; color: #a0407a; }
.status-replaced  { background: #f0ecfd; color: #9b7ec8; }

/* 卡片中部 */
.card-body { margin-bottom: 24rpx; }
.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.label {
  font-size: 26rpx;
  color: #999;
  width: 130rpx;
}
.value {
  font-size: 28rpx;
  color: #333;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}
.onboard-tag {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}
.onboard-tag.pending   { background: #f0ecfd; color: #8766F3; }
.onboard-tag.confirmed { background: #8766F3; color: #fff; }
.arrow { font-size: 40rpx; color: #bbb; margin-left: auto; }
.sign-btn {
  font-size: 26rpx; color: #fff;
  background: #8766F3;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
}
.onboard-btn {
  font-size: 26rpx; color: #8766F3;
  border: 1rpx solid #8766F3;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
}
.card-footer-end {
  justify-content: flex-end;
  gap: 16rpx;
}

/* 职培 - 学员档案卡 */
.training-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 0 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.training-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #8766F3;
}
.training-card-title-outer {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  margin: 0 20rpx 16rpx;
}

/* 职培合同号 */
.contract-no {
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}

/* 应付金额行 */
.value-row {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 16rpx;
}
.value-strong {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff6b00;
}

/* 立即支付按钮 */
.pay-btn {
  font-size: 26rpx;
  color: #fff;
  background: #ff6b00;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
  margin-left: auto;
}
.pay-btn-disabled {
  opacity: 0.55;
}
.paid-tag {
  font-size: 24rpx;
  color: #2bb673;
  margin-left: auto;
}

