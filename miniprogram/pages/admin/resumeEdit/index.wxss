.page {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  background: #F7F5FF;
  border-radius: 12rpx;
  padding: 18rpx 18rpx;
  font-size: 28rpx;
}


.picker {
  background: #F7F5FF;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 28rpx;
  color: #333;
}


.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.btn {
  text-align: center;
  border-radius: 12rpx;
  padding: 18rpx 0;
  background: #F1EEFF;
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-size: 28rpx;
  margin-top: 14rpx;
}

.primary {
  background: linear-gradient(135deg, #8766F3 0%, #A694FF 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(135, 102, 243, 0.3);
}


.danger {
  color: #e54545;
}

.media-row {
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.media-actions {
  flex: 1;
}

.photo-row {
  white-space: nowrap;
}

.photo {
  width: 220rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  margin-right: 14rpx;
  display: inline-block;
}

.video {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  background: #000;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  background: #F7F5FF;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}


.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 20rpx;
  background: rgba(246, 246, 246, 0.9);
  backdrop-filter: blur(10px);
}
