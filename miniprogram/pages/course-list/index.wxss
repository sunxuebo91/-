.page {
  min-height: 100vh;
  background: #F4F4F7;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

/* 状态页 */
.state-wrap {
  padding: 160rpx 40rpx;
  text-align: center;
}
.state-icon { font-size: 80rpx; }
.state-text { font-size: 30rpx; color: #666; margin-top: 16rpx; }
.state-sub  { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.primary-btn {
  display: inline-block;
  margin-top: 48rpx;
  background: #8b5cf6;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 64rpx;
  border-radius: 48rpx;
}
.ghost-btn {
  display: inline-block;
  margin-top: 48rpx;
  border: 1rpx solid #8b5cf6;
  color: #8b5cf6;
  font-size: 28rpx;
  padding: 20rpx 64rpx;
  border-radius: 48rpx;
  background: #fff;
}

/* 列表：双列网格 */
.list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.course-card {
  width: calc((100% - 20rpx) / 2);
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(20, 14, 60, 0.04);
  transition: transform 0.18s ease;
  box-sizing: border-box;
}
.course-card--hover {
  transform: scale(0.97);
}

/* 封面：占满卡片宽度，按 16:9 比例显示完整图 */
.cover-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
  background: linear-gradient(135deg, #F4F1EC, #ECECEF);
  overflow: hidden;
}
.course-cover {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.course-meta {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
  gap: 8rpx;
}
.course-title {
  font-size: 26rpx;
  color: #1c1c24;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 70rpx;
}
.sub-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}
.course-sub {
  font-size: 20rpx;
  color: #9b9ba8;
}
.status-dot {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  line-height: 1.6;
}
.status-dot.status-done {
  color: #059669;
  background: rgba(16, 185, 129, 0.1);
}
.status-dot.status-progress {
  color: #6d49e8;
  background: rgba(139, 92, 246, 0.1);
}
.status-dot.status-idle {
  color: #9b9ba8;
  background: rgba(155, 155, 168, 0.12);
}

.progress-row {
  margin-top: 4rpx;
}
.progress-track {
  width: 100%;
  height: 6rpx;
  background: #ECECF2;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.4s ease;
}
.progress-fill--done {
  background: linear-gradient(90deg, #10B981, #059669);
}
.progress-fill--progress {
  background: linear-gradient(90deg, #8b5cf6, #6d49e8);
}
.progress-fill--idle {
  background: transparent;
}
.progress-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.progress-text {
  font-size: 20rpx;
  color: #8b8b96;
}
.progress-percent {
  font-size: 20rpx;
  font-weight: 600;
  color: #6d49e8;
}

.footer-action {
  margin-top: 60rpx;
  text-align: center;
}
.logout-link {
  display: inline-block;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 32rpx;
}
