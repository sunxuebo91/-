.page {
  min-height: 100vh;
  background: #F7F5FF;
  padding: 24rpx 20rpx 40rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #111;
  margin-bottom: 20rpx;
}

.loading {
  padding: 60rpx 0;
  text-align: center;
  color: #888;
  font-size: 26rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: #888;
  font-size: 26rpx;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.section-hd {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111;
}

.section-count {
  font-size: 22rpx;
  color: #999;
  font-weight: 700;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.thumb {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f2f2f2;
}
