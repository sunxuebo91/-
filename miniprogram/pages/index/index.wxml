<!--index.wxml-->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="navbar">
    <view class="location">
      <image class="location-icon" src="../../images/location.png" mode="aspectFit"></image>
      <text class="location-text">北京市朝阳区</text>
    </view>
    <view class="navbar-title">天樾到家</view>
    <view class="navbar-actions">
      <image class="action-icon" src="../../images/menu.png" mode="aspectFit"></image>
      <image class="action-icon" src="../../images/scan.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- Banner轮播 -->
  <view class="banner-container">
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff" autoplay circular>
      <swiper-item>
        <view class="banner-item">
          <view class="banner-content">
            <view class="banner-title">新手妈妈的好帮手</view>
            <view class="banner-subtitle">金牌月嫂 马上面试！</view>
          </view>
          <image class="banner-image" src="../../images/banner-1.png" mode="aspectFit"></image>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 特色服务标签 -->
  <view class="feature-tags">
    <view class="feature-tag">
      <image class="feature-icon" src="../../images/icon-support.png" mode="aspectFit"></image>
      <text class="feature-text">互联网家政领导者</text>
    </view>
    <view class="feature-tag">
      <image class="feature-icon" src="../../images/icon-training.png" mode="aspectFit"></image>
      <text class="feature-text">100小时专业培训</text>
    </view>
    <view class="feature-tag">
      <image class="feature-icon" src="../../images/icon-price.png" mode="aspectFit"></image>
      <text class="feature-text">标准定价 售后无忧</text>
    </view>
  </view>

  <!-- 服务分类 -->
  <view class="service-grid">
    <view class="service-item" bindtap="goService" data-type="nanny">
      <image class="service-icon" src="../../images/service-nanny.png" mode="aspectFit"></image>
      <text class="service-name">保姆</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="maternity">
      <image class="service-icon" src="../../images/service-maternity.png" mode="aspectFit"></image>
      <text class="service-name">月嫂</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="childcare">
      <image class="service-icon" src="../../images/service-childcare.png" mode="aspectFit"></image>
      <text class="service-name">育儿嫂</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="cooking">
      <image class="service-icon" src="../../images/service-cooking.png" mode="aspectFit"></image>
      <text class="service-name">日常保洁</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="cleaning">
      <image class="service-icon" src="../../images/service-cleaning.png" mode="aspectFit"></image>
      <text class="service-name">家电清洗</text>
    </view>
  </view>

  <view class="service-grid">
    <view class="service-item" bindtap="goService" data-type="meal">
      <image class="service-icon" src="../../images/service-meal.png" mode="aspectFit"></image>
      <text class="service-name">整理保洁</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="nursing">
      <image class="service-icon" src="../../images/service-nursing.png" mode="aspectFit"></image>
      <text class="service-name">油烟机清洗</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="maintenance">
      <image class="service-icon" src="../../images/service-maintenance.png" mode="aspectFit"></image>
      <text class="service-name">家电维修</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="meal-prep">
      <image class="service-icon" src="../../images/service-meal-prep.png" mode="aspectFit"></image>
      <text class="service-name">做饭钟点工</text>
    </view>
    <view class="service-item" bindtap="goService" data-type="renovation">
      <image class="service-icon" src="../../images/service-renovation.png" mode="aspectFit"></image>
      <text class="service-name">房屋维修</text>
    </view>
  </view>

  <!-- 专业服务卡片 -->
  <view class="pro-cards">
    <view class="pro-card pro-card-red" bindtap="goResumeList" data-type="nanny">
      <view class="pro-card-content">
        <view class="pro-card-title">专业保姆</view>
        <view class="pro-card-subtitle">素质强硬 不属收嫁</view>
      </view>
      <image class="pro-card-image" src="../../images/pro-nanny.png" mode="aspectFit"></image>
    </view>
    <view class="pro-card pro-card-pink" bindtap="goResumeList" data-type="maternity">
      <view class="pro-card-content">
        <view class="pro-card-title">专业月嫂</view>
        <view class="pro-card-subtitle">慈悲细意 产检丰富</view>
      </view>
      <image class="pro-card-image" src="../../images/pro-maternity.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 超值服务 -->
  <view class="value-section">
    <view class="section-header">
      <text class="section-title">超值服务</text>
      <text class="section-more">优惠升级，保惠不断</text>
    </view>
    <view class="value-cards">
      <view class="value-card value-card-orange">
        <view class="value-tag">低至52元/小时</view>
        <view class="value-title">做饭钟点工</view>
        <view class="value-subtitle">新客特惠最3次套餐</view>
        <image class="value-image" src="../../images/value-1.png" mode="aspectFit"></image>
      </view>
      <view class="value-card value-card-blue">
        <view class="value-tag">低至8.8折</view>
        <view class="value-title">双面擦玻璃</view>
        <view class="value-subtitle">清洁看得见</view>
        <image class="value-image" src="../../images/value-2.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>
</view>