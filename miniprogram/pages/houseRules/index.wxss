/* ============================================
 * 上户须知 · 文档手册式排版
 * 主色：深紫靛 #3D2E7E（权威色，品牌延伸）
 * 警示：暖朱红 #DC2626 / 朱砂红 #A82418（暖红，不用血红，避免挽联感）
 * 底色：暖米白 #FAF7F2 / 暖红底 #FEF7F0
 * 设计原则：印章 / 水印 / 报头色条 三层视觉锚点
 * ============================================ */

page {
  background: #F5F3EF;
  min-height: 100vh;
}

.house-rules-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 64rpx;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* ===== 文档标题（报头式） ===== */
.doc-header {
  background: #fff;
  border: 1rpx solid #E5E5EA;
  border-radius: 4rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
}

.doc-header__tape {
  height: 8rpx;
  background: #3D2E7E;
}

.doc-header__inner {
  padding: 40rpx 32rpx 32rpx;
  text-align: center;
  position: relative;
}

.doc-header__inner::before,
.doc-header__inner::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  height: 1rpx;
  background: #3D2E7E;
}

.doc-header__inner::before {
  top: 22rpx;
  opacity: 0.6;
}

.doc-header__inner::after {
  display: none;
}

.doc-header__eyebrow {
  font-size: 20rpx;
  color: #6E6E73;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
  font-family: "SF Mono", Menlo, monospace;
}

.doc-header__title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2A1F5C;
  letter-spacing: 6rpx;
  line-height: 1.2;
}

.doc-header__divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 22rpx 0 18rpx;
  gap: 10rpx;
}

.doc-header__divider-dot {
  width: 8rpx;
  height: 8rpx;
  background: #3D2E7E;
  transform: rotate(45deg);
}

.doc-header__divider-line {
  width: 80rpx;
  height: 2rpx;
  background: #3D2E7E;
}

.doc-header__meta {
  font-size: 24rpx;
  color: #3A3A40;
  letter-spacing: 1rpx;
  font-weight: 500;
}

.doc-header__chapters {
  font-size: 22rpx;
  color: #8E8E93;
  letter-spacing: 1rpx;
  margin-top: 8rpx;
}

/* ===== 红线说明（左侧印章式大字"禁"） ===== */
.redline-notice {
  display: flex;
  background: #FFFFFF;
  border: 1rpx solid #E5DFD2;
  border-radius: 4rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  min-height: 168rpx;
}

.redline-notice__mark {
  width: 120rpx;
  background: #3D2E7E;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.redline-notice__mark::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  border: 2rpx solid rgba(245, 197, 24, 0.45);
  border-radius: 4rpx;
}

.redline-notice__mark-char {
  font-size: 72rpx;
  font-weight: 700;
  color: #F5C518;
  letter-spacing: 0;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  line-height: 1;
}

.redline-notice__body {
  flex: 1;
  padding: 24rpx 28rpx;
  min-width: 0;
}

.redline-notice__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #DC2626;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #F2DDD0;
}

.redline-notice__desc {
  font-size: 25rpx;
  line-height: 1.75;
  color: #3A3A40;
}

.redline-notice__strong {
  color: #DC2626;
  font-weight: 600;
}

.inline-mark {
  display: inline-block;
  padding: 0 4rpx;
  font-size: 22rpx;
  vertical-align: -2rpx;
}

/* ===== 章节列表 ===== */
.section-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* ===== 章节卡片 ===== */
.section-card {
  background: #fff;
  border: 1rpx solid #E5DFD2;
  border-left: 5rpx solid #3D2E7E;
  border-radius: 4rpx;
  overflow: hidden;
}

.section-card--critical {
  border-color: #EBD4C8;
  border-left-color: #DC2626;
}

/* ----- 章节标题栏 ----- */
.section-head {
  position: relative;
  border-bottom: 1rpx solid #EFEAE0;
  background: #FAF7F2;
  overflow: hidden;
}

.section-card--critical .section-head {
  background: #FEF7F0;
  border-bottom-color: #F2DDD0;
}

/* 大号中文数字水印 —— 仿古籍/法典纵深感 */
.section-head__watermark {
  position: absolute;
  right: -16rpx;
  bottom: -48rpx;
  font-size: 220rpx;
  font-weight: 900;
  color: rgba(61, 46, 126, 0.06);
  font-family: "Songti SC", "STSong", "SimSun", serif;
  line-height: 1;
  pointer-events: none;
}

.section-card--critical .section-head__watermark {
  color: rgba(220, 38, 38, 0.07);
}

.section-head__main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx 24rpx;
}

/* 实心印章式序号 */
.section-head__num {
  width: 56rpx;
  height: 56rpx;
  background: #3D2E7E;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  box-shadow: 0 1rpx 0 rgba(0, 0, 0, 0.06);
}

.section-card--critical .section-head__num {
  background: #DC2626;
}

.section-head__title-wrap {
  flex: 1;
  min-width: 0;
}

.section-head__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A1F5C;
  line-height: 1.3;
  letter-spacing: 2rpx;
}

.section-head__subtitle {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

.section-head__count {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.section-head__tag {
  font-size: 18rpx;
  font-weight: 700;
  color: #DC2626;
  border: 1rpx solid #DC2626;
  padding: 2rpx 10rpx;
  letter-spacing: 2rpx;
  line-height: 1.4;
  font-family: "SF Mono", Menlo, monospace;
}

.section-head__count-text {
  font-size: 22rpx;
  color: #8E8E93;
  letter-spacing: 1rpx;
}

/* ----- 条目列表 ----- */
.item-list {
  padding: 0 28rpx;
}

.rule-row {
  display: flex;
  align-items: flex-start;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F2F2F5;
  position: relative;
}

.rule-row:last-child {
  border-bottom: none;
}

.rule-row__lead {
  flex-shrink: 0;
  width: 48rpx;
  margin-right: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-top: 2rpx;
}

.rule-row__no {
  font-size: 24rpx;
  font-weight: 500;
  color: #8E8E93;
  font-family: "SF Mono", Menlo, monospace;
}

.rule-row__forbid {
  font-size: 28rpx;
  line-height: 1;
}

.rule-row__text {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.75;
  color: #2D2A38;
  letter-spacing: 0.5rpx;
}

/* 红线条款行 —— 暖米底 + 暖红左竖线 + 朱砂红文字 */
.rule-row--red {
  background: #FEF7F0;
  margin: 0 -28rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  border-bottom-color: #F2DDD0;
}

.rule-row--red::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3rpx;
  background: #DC2626;
}

.rule-row--red .rule-row__text {
  color: #A82418;
  font-weight: 500;
}

/* 强调行（非红线但加粗显眼） */
.rule-row--emphasis .rule-row__text {
  color: #2A1F5C;
  font-weight: 700;
}

/* ===== 底部声明（印章式签名） ===== */
.footer-statement {
  margin-top: 56rpx;
  padding-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-statement__rule {
  width: 64rpx;
  height: 2rpx;
  background: #3D2E7E;
  margin-bottom: 24rpx;
}

.footer-statement__text {
  font-size: 24rpx;
  color: #3A3A40;
  letter-spacing: 2rpx;
  margin-bottom: 28rpx;
}

.footer-statement__seal {
  width: 180rpx;
  height: 180rpx;
  border: 3rpx solid #DC2626;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transform: rotate(-6deg);
  opacity: 0.92;
}

.footer-statement__seal::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border: 1rpx solid #DC2626;
  border-radius: 50%;
  opacity: 0.5;
}

.footer-statement__seal-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #DC2626;
}

.footer-statement__seal-top {
  font-size: 16rpx;
  letter-spacing: 3rpx;
  font-family: "SF Mono", Menlo, monospace;
  font-weight: 700;
}

.footer-statement__seal-mid {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin: 4rpx 0;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.footer-statement__seal-bot {
  font-size: 14rpx;
  letter-spacing: 2rpx;
  font-family: "SF Mono", Menlo, monospace;
  font-weight: 700;
  opacity: 0.85;
}

