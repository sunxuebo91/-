<view class="house-rules-page">
  <!-- 文档式标题（顶部黑条 + 印刷式排版） -->
  <view class="doc-header">
    <view class="doc-header__tape"></view>
    <view class="doc-header__inner">
      <view class="doc-header__eyebrow">ANDE · HOUSEKEEPING CODE</view>
      <view class="doc-header__title">上 户 须 知</view>
      <view class="doc-header__divider">
        <view class="doc-header__divider-dot"></view>
        <view class="doc-header__divider-line"></view>
        <view class="doc-header__divider-dot"></view>
      </view>
      <view class="doc-header__meta">阿姨服务行为规范与工作标准</view>
      <view class="doc-header__chapters">全文共 10 章 · 阅读时长约 5 分钟</view>
    </view>
  </view>

  <!-- 红线说明（左侧大字印章式） -->
  <view class="redline-notice">
    <view class="redline-notice__mark">
      <view class="redline-notice__mark-char">禁</view>
    </view>
    <view class="redline-notice__body">
      <view class="redline-notice__title">红 线 条 款 说 明</view>
      <view class="redline-notice__desc">
        本须知是阿姨上户服务的行为规范和工作标准，请逐条阅读并严格遵守。条款前标有 <text class="inline-mark">🚫</text> 的为<text class="redline-notice__strong">红线条款</text>，违反将按公司规定处理，<text class="redline-notice__strong">情节严重者立即解约并追究相应责任</text>。
      </view>
    </view>
  </view>

  <!-- 章节列表 -->
  <view class="section-list">
    <view
      class="section-card {{section.tone === 'critical' ? 'section-card--critical' : ''}}"
      wx:for="{{sections}}"
      wx:for-item="section"
      wx:key="idx"
    >
      <!-- 章节标题 -->
      <view class="section-head">
        <view class="section-head__watermark">{{section.idx}}</view>
        <view class="section-head__main">
          <view class="section-head__num">{{section.idx}}</view>
          <view class="section-head__title-wrap">
            <view class="section-head__title">{{section.title}}</view>
            <view class="section-head__subtitle" wx:if="{{section.subtitle}}">{{section.subtitle}}</view>
          </view>
          <view class="section-head__count">
            <text wx:if="{{section.tone === 'critical'}}" class="section-head__tag">RED LINE</text>
            <text class="section-head__count-text">共 {{section.items.length}} 条</text>
          </view>
        </view>
      </view>

      <!-- 条目列表 -->
      <view class="item-list">
        <view
          class="rule-row {{item.red ? 'rule-row--red' : ''}} {{item.emphasis ? 'rule-row--emphasis' : ''}}"
          wx:for="{{section.items}}"
          wx:for-item="item"
          wx:key="text"
        >
          <view class="rule-row__lead">
            <text wx:if="{{item.red}}" class="rule-row__forbid">🚫</text>
            <text wx:else class="rule-row__no">{{index + 1}}</text>
          </view>
          <view class="rule-row__text">{{item.text}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部印章式签名 -->
  <view class="footer-statement">
    <view class="footer-statement__rule"></view>
    <view class="footer-statement__text">阅读即视为知晓并承诺遵守上述全部条款</view>
    <view class="footer-statement__seal">
      <view class="footer-statement__seal-inner">
        <view class="footer-statement__seal-top">ANDE</view>
        <view class="footer-statement__seal-mid">安 得 褓 贝</view>
        <view class="footer-statement__seal-bot">SERVICE CODE</view>
      </view>
    </view>
  </view>
</view>

