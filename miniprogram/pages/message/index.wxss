page {
  background: #f7f7fb;
  min-height: 100vh;
}

.message-page {
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 客服快捷入口 */
.customer-service-card {
  position: relative;
  margin: 24rpx 32rpx;
  width: calc(100% - 64rpx);
  height: 152rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #F5222D 0%, #FF4D4F 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(245, 34, 45, 0.3);
  transition: all 0.2s ease;
  /* 重置 button 样式 */
  border: none;
  line-height: normal;
  text-align: left;
}

.customer-service-card::after {
  border: none;
}

/* 联系客服覆盖按钮：确保与上方测试卡完全等宽等高 */
.contact-overlay {
  position: absolute;
  inset: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 24rpx;
  opacity: 0;
}

.contact-overlay::after {
  border: none;
}

.customer-service-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(245, 34, 45, 0.2);
}

.cs-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.cs-icon {
  width: 80rpx;
  height: 80rpx;
  filter: brightness(0) invert(1);
}

.cs-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cs-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.cs-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.cs-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

/* 消息列表 */
.message-list {
  padding: 0 32rpx;
}

.message-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.message-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.message-icon-wrapper {
  position: relative;
  flex-shrink: 0;
}

.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.unread-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff4d4f;
  border-radius: 50%;
  border: 3rpx solid #fff;
}

.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.message-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.message-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 120rpx 32rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #999;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}
