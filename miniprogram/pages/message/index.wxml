<view class="message-page">
  <!-- 客服快捷入口 -->
  <view class="customer-service-card contact-card">
    <view class="cs-left">
      <image class="cs-icon" src="/images/icons/customer-service.svg" mode="aspectFit"></image>
      <view class="cs-info">
        <view class="cs-title">联系客服</view>
        <view class="cs-subtitle">专业解答 贴心服务</view>
      </view>
    </view>
    <view class="cs-arrow">›</view>
    <button class="contact-overlay" open-type="{{isLoggedIn ? 'contact' : ''}}" bindtap="onContactTap" bindcontact="handleContact" hover-class="none"></button>
  </view>

  <!-- 通知列表头部 -->
  <view class="msg-header" wx:if="{{messages.length > 0}}">
    <view class="msg-header-title">消息通知</view>
    <view class="msg-mark-all" bindtap="onMarkAllRead">
      <text class="msg-mark-all-text {{unreadCount === 0 ? 'disabled' : ''}}">全部已读</text>
    </view>
  </view>

  <!-- 通知列表 -->
  <view class="message-list" wx:if="{{messages.length > 0}}">
    <view class="msg-group" wx:for="{{messages}}" wx:key="id">
      <!-- 时间浮在卡片左上方 -->
      <view class="msg-timestamp">{{item.time}}</view>
      <!-- 通知卡片 -->
      <view
        class="message-item {{item.read ? 'read' : ''}}"
        bindtap="onMessageTap"
        data-id="{{item.id}}"
        data-type="{{item.type}}"
        data-contractid="{{item.contractId}}"
        data-read="{{item.read}}"
      >
        <!-- 类型图标 -->
        <view class="msg-icon-wrap" style="background:{{item.color}}20;">
          <text class="msg-emoji">{{item.emoji}}</text>
          <view class="unread-badge" wx:if="{{!item.read}}"></view>
        </view>
        <!-- 内容 -->
        <view class="message-content">
          <view class="message-header">
            <view class="message-title {{item.read ? 'read' : ''}}">{{item.title}}</view>
            <view wx:if="{{item.showSignBtn}}" class="msg-action-btn" catchtap="onActionBtnTap" data-id="{{item.id}}" data-contractid="{{item.contractId}}" data-type="{{item.type}}" data-read="{{item.read}}">去签署 →</view>
          </view>
          <view class="message-desc">{{item.content}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && messages.length === 0}}">
    <image class="empty-icon" src="/images/icons/message-empty.svg" mode="aspectFit"></image>
    <text class="empty-text">暂无消息</text>
    <text class="empty-hint">合同、付款、上户等通知将在这里显示</text>
  </view>

  <!-- 加载中 -->
  <view class="empty-state" wx:if="{{loading}}">
    <text class="empty-hint">加载中...</text>
  </view>
</view>
