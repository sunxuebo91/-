.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 -10rpx 30rpx rgba(17, 24, 39, 0.10);
}

.tab-bar-pill {
  width: 100%;
  height: 112rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  padding-top: 16rpx;
  overflow: visible;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tab-bar-item:active {
  opacity: 0.85;
}

.normal-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  row-gap: 6rpx;
  width: 100%;
}

.icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  transition: all 0.2s ease;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.text {
  font-size: 22rpx;
  line-height: 1.1;
  color: #9ca3af;
  font-weight: 600;
  transition: color 0.2s ease;
}

.text.active {
  color: #8766f3;
}

/* 消息未读红点 */
.tab-badge {
  position: absolute;
  top: -6rpx;
  right: -10rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: #ff4d4f;
  border-radius: 14rpx;
  border: 3rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  box-sizing: border-box;
}

.tab-badge-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

