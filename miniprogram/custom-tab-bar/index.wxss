.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.tab-bar-pill {
  width: 100%;
  height: 112rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  padding-top: 16rpx;
  overflow: visible;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tab-bar-item:active {
  opacity: 0.85;
}

.normal-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  row-gap: 6rpx;
  width: 100%;
}

.icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  transition: all 0.2s ease;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.text {
  font-size: 22rpx;
  line-height: 1.1;
  color: #9ca3af;
  font-weight: 600;
  transition: color 0.2s ease;
}

.text.active {
  color: #8766f3;
}

